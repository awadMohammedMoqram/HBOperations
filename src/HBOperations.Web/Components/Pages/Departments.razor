@page "/departments"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using HBOperations.Application.Common.Interfaces
@using Microsoft.EntityFrameworkCore
@inject IAppDbContext DbContext

<PageTitle>الأقسام - بنك حضرموت</PageTitle>

<div class="page-container hb-fade-in">
    <div class="page-title-section">
        <div class="title-with-action">
            <div>
                <h1 class="section-title"><i class="bi bi-diagram-3-fill"></i> إدارة الأقسام</h1>
                <p class="section-subtitle">عرض وإدارة الأقسام والإدارات في البنك</p>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="dept-stats">
        <div class="stat-item">
            <i class="bi bi-diagram-3-fill"></i>
            <span class="stat-number">@_departments.Count</span>
            <span class="stat-label">إجمالي الأقسام</span>
        </div>
        <div class="stat-item stat-active">
            <i class="bi bi-check-circle-fill"></i>
            <span class="stat-number">@_departments.Count(d => d.IsActive)</span>
            <span class="stat-label">نشط</span>
        </div>
        <div class="stat-item stat-inactive">
            <i class="bi bi-pause-circle-fill"></i>
            <span class="stat-number">@_departments.Count(d => !d.IsActive)</span>
            <span class="stat-label">غير نشط</span>
        </div>
    </div>

    @if (_loading)
    {
        <div class="hb-loading"><div class="hb-spinner"></div><span>جاري تحميل الأقسام...</span></div>
    }
    else
    {
        <div class="table-container">
            <table class="hb-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>اسم القسم</th>
                        <th>الرمز</th>
                        <th>القسم الرئيسي</th>
                        <th>عدد الأقسام الفرعية</th>
                        <th>الحالة</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var index = 0; }
                    @foreach (var dept in _departments)
                    {
                        index++;
                        <tr>
                            <td>@index</td>
                            <td>
                                <div class="dept-name">
                                    <i class="bi bi-diagram-3"></i>
                                    @dept.NameAr
                                </div>
                            </td>
                            <td><span class="code-badge">@dept.Code</span></td>
                            <td>@(dept.ParentDepartment?.NameAr ?? "—")</td>
                            <td class="text-center">@dept.ChildDepartments.Count</td>
                            <td>
                                @if (dept.IsActive)
                                {
                                    <span class="hb-badge-success">نشط</span>
                                }
                                else
                                {
                                    <span class="hb-badge-secondary">غير نشط</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<HBOperations.Domain.Entities.Department> _departments = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _departments = await DbContext.Departments
            .Include(d => d.ParentDepartment)
            .Include(d => d.ChildDepartments)
            .OrderBy(d => d.Code)
            .AsNoTracking()
            .ToListAsync();

        _loading = false;
    }
}
