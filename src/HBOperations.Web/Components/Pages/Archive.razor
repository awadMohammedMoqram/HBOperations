@page "/archive"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using HBOperations.Application.Common.Interfaces
@using HBOperations.Domain.Entities
@using HBOperations.Domain.Enums
@using Microsoft.EntityFrameworkCore
@inject IAppDbContext DbContext
@inject ISystemSettingService SettingService

<PageTitle>الأرشيف - بنك حضرموت</PageTitle>

<div class="page-container hb-fade-in">
    <div class="page-title-section">
        <div class="title-with-action">
            <div>
                <h1 class="section-title"><i class="bi bi-archive-fill"></i> أرشيف المعاملات</h1>
                <p class="section-subtitle">المعاملات المؤرشفة تلقائياً بعد @_archiveDays يوم من الإكمال</p>
            </div>
            <div class="archive-actions-top">
                <button class="btn-hb-outline" @onclick="ManualArchive" disabled="@_archiving">
                    @if (_archiving)
                    {
                        <span class="hb-spinner-sm"></span>
                    }
                    else
                    {
                        <i class="bi bi-archive"></i>
                    }
                    أرشفة يدوية الآن
                </button>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="archive-stats">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-archive-fill"></i></div>
            <div class="stat-body">
                <span class="stat-number">@_archivedCount</span>
                <span class="stat-label">معاملة مؤرشفة</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-docs"><i class="bi bi-file-earmark-fill"></i></div>
            <div class="stat-body">
                <span class="stat-number">@_archivedDocs</span>
                <span class="stat-label">مستند مؤرشف</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-ready"><i class="bi bi-clock-history"></i></div>
            <div class="stat-body">
                <span class="stat-number">@_readyToArchive</span>
                <span class="stat-label">جاهزة للأرشفة</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-auto"><i class="bi @(_autoArchiveEnabled ? "bi-toggle-on" : "bi-toggle-off")"></i></div>
            <div class="stat-body">
                <span class="stat-number">@(_autoArchiveEnabled ? "مفعّل" : "معطّل")</span>
                <span class="stat-label">الأرشفة التلقائية</span>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="hb-alert @(_isError ? "hb-alert-danger" : "hb-alert-success")">
            <i class="bi @(_isError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i> @_message
        </div>
    }

    <!-- Search -->
    <div class="search-bar">
        <div class="search-input-wrap">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="بحث في الأرشيف..." @bind="_searchTerm" @bind:event="oninput" />
        </div>
        <select class="filter-select" @bind="_typeFilter">
            <option value="">كل الأنواع</option>
            @foreach (TransactionType t in Enum.GetValues<TransactionType>())
            {
                <option value="@((int)t)">@GetTypeLabel(t)</option>
            }
        </select>
    </div>

    @if (_loading)
    {
        <div class="hb-loading"><div class="hb-spinner"></div><span>جاري تحميل الأرشيف...</span></div>
    }
    else if (!GetFiltered().Any())
    {
        <div class="empty-state">
            <i class="bi bi-archive"></i>
            <h3>لا توجد معاملات مؤرشفة</h3>
            <p>ستظهر المعاملات هنا بعد أرشفتها تلقائياً أو يدوياً</p>
        </div>
    }
    else
    {
        <div class="table-container">
            <table class="hb-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>رقم المرجع</th>
                        <th>الموضوع</th>
                        <th>النوع</th>
                        <th>فرع الإرسال</th>
                        <th>فرع الاستلام</th>
                        <th>تاريخ الإكمال</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var index = (_currentPage - 1) * _pageSize; }
                    @foreach (var tx in GetPaginated())
                    {
                        index++;
                        <tr>
                            <td>@index</td>
                            <td><span class="ref-num">@tx.ReferenceNumber</span></td>
                            <td>@tx.Subject</td>
                            <td><span class="type-badge">@GetTypeLabel(tx.Type)</span></td>
                            <td>@(tx.SenderBranch?.NameAr ?? "—")</td>
                            <td>@(tx.ReceiverBranch?.NameAr ?? "—")</td>
                            <td>@(tx.CompletedAt?.ToString("yyyy/MM/dd") ?? "—")</td>
                            <td>
                                <div class="action-btns">
                                    <a href="/transactions/@tx.Id" class="action-btn" title="عرض التفاصيل">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button class="action-btn action-restore" title="استعادة من الأرشيف"
                                            @onclick="() => OpenRestoreModal(tx)">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_totalPages > 1)
        {
            <div class="pagination">
                <button class="page-btn" disabled="@(_currentPage <= 1)" @onclick="() => _currentPage--">
                    <i class="bi bi-chevron-right"></i>
                </button>
                <span class="page-info">@_currentPage / @_totalPages</span>
                <button class="page-btn" disabled="@(_currentPage >= _totalPages)" @onclick="() => _currentPage++">
                    <i class="bi bi-chevron-left"></i>
                </button>
            </div>
        }
    }

    <!-- Restore Modal -->
    @if (_showRestoreModal && _selectedTx is not null)
    {
        <div class="modal-overlay" @onclick="() => _showRestoreModal = false">
            <div class="modal-content" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3><i class="bi bi-arrow-counterclockwise"></i> استعادة من الأرشيف</h3>
                    <button class="modal-close" @onclick="() => _showRestoreModal = false">×</button>
                </div>
                <div class="modal-body">
                    <p>هل تريد استعادة المعاملة <strong>@_selectedTx.ReferenceNumber</strong> من الأرشيف؟</p>
                    <p class="modal-note">سيتم إرجاع حالة المعاملة إلى "مؤكدة"</p>
                </div>
                <div class="modal-footer">
                    <button class="btn-hb-outline" @onclick="() => _showRestoreModal = false">إلغاء</button>
                    <button class="btn-hb-primary" @onclick="RestoreTransaction">
                        <i class="bi bi-arrow-counterclockwise"></i> استعادة
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Transaction> _archived = [];
    private bool _loading = true;
    private bool _archiving;
    private string? _message;
    private bool _isError;
    private string _searchTerm = "";
    private string _typeFilter = "";
    private int _currentPage = 1;
    private int _pageSize = 20;
    private int _totalPages;

    // Stats
    private int _archivedCount;
    private int _archivedDocs;
    private int _readyToArchive;
    private bool _autoArchiveEnabled;
    private int _archiveDays;

    // Restore modal
    private bool _showRestoreModal;
    private Transaction? _selectedTx;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _loading = false;
    }

    private async Task LoadData()
    {
        _archived = await DbContext.Transactions
            .AsNoTracking()
            .Include(t => t.SenderBranch)
            .Include(t => t.ReceiverBranch)
            .Where(t => t.Status == TransactionStatus.Archived)
            .OrderByDescending(t => t.CompletedAt)
            .ToListAsync();

        _archivedCount = _archived.Count;
        _archivedDocs = await DbContext.TransactionDocuments.CountAsync(d => d.IsArchived);

        _archiveDays = await SettingService.GetIntAsync("AutoArchive.DaysAfterCompletion", 90);
        _autoArchiveEnabled = await SettingService.GetBoolAsync("AutoArchive.Enabled", true);

        var cutoff = DateTime.UtcNow.AddDays(-_archiveDays);
        _readyToArchive = await DbContext.Transactions
            .CountAsync(t => (t.Status == TransactionStatus.Confirmed || t.Status == TransactionStatus.Cancelled)
                            && t.CompletedAt.HasValue
                            && t.CompletedAt.Value < cutoff);
    }

    private List<Transaction> GetFiltered()
    {
        var result = _archived.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchTerm))
            result = result.Where(t => t.ReferenceNumber.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
                                    || t.Subject.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrEmpty(_typeFilter) && int.TryParse(_typeFilter, out var typeVal))
            result = result.Where(t => (int)t.Type == typeVal);

        return result.ToList();
    }

    private List<Transaction> GetPaginated()
    {
        var filtered = GetFiltered();
        _totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)_pageSize));
        if (_currentPage > _totalPages) _currentPage = _totalPages;
        return filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();
    }

    private async Task ManualArchive()
    {
        _archiving = true;
        _message = null;

        try
        {
            var cutoff = DateTime.UtcNow.AddDays(-_archiveDays);
            var toArchive = await DbContext.Transactions
                .Where(t => (t.Status == TransactionStatus.Confirmed || t.Status == TransactionStatus.Cancelled)
                            && t.CompletedAt.HasValue && t.CompletedAt.Value < cutoff)
                .ToListAsync();

            if (toArchive.Count == 0)
            {
                _message = "لا توجد معاملات جاهزة للأرشفة";
                _archiving = false;
                return;
            }

            foreach (var tx in toArchive)
                tx.Status = TransactionStatus.Archived;

            var txIds = toArchive.Select(t => t.Id).ToHashSet();
            var docs = await DbContext.TransactionDocuments
                .Where(d => txIds.Contains(d.TransactionId) && !d.IsArchived)
                .ToListAsync();

            foreach (var doc in docs)
                doc.IsArchived = true;

            await DbContext.SaveChangesAsync();
            _message = $"تم أرشفة {toArchive.Count} معاملة و {docs.Count} مستند بنجاح";
            await LoadData();
        }
        catch
        {
            _message = "حدث خطأ أثناء الأرشفة";
            _isError = true;
        }
        finally
        {
            _archiving = false;
        }
    }

    private void OpenRestoreModal(Transaction tx)
    {
        _selectedTx = tx;
        _showRestoreModal = true;
    }

    private async Task RestoreTransaction()
    {
        if (_selectedTx is null) return;

        try
        {
            var tx = await DbContext.Transactions.FindAsync(_selectedTx.Id);
            if (tx is null) return;

            tx.Status = TransactionStatus.Confirmed;

            // Unarchive documents
            var docs = await DbContext.TransactionDocuments
                .Where(d => d.TransactionId == tx.Id && d.IsArchived)
                .ToListAsync();

            foreach (var doc in docs)
                doc.IsArchived = false;

            await DbContext.SaveChangesAsync();
            _showRestoreModal = false;
            _message = $"تم استعادة المعاملة {_selectedTx.ReferenceNumber} بنجاح";
            _isError = false;
            await LoadData();
        }
        catch
        {
            _message = "حدث خطأ أثناء الاستعادة";
            _isError = true;
        }
    }

    private static string GetTypeLabel(TransactionType t) => t switch
    {
        TransactionType.OutgoingFromHQ => "صادر من الإدارة",
        TransactionType.IncomingToHQ => "وارد للإدارة",
        TransactionType.BranchToBranch => "بين الفروع",
        TransactionType.InternalDepartment => "داخلي",
        TransactionType.DocumentDelivery => "تسليم مستندات",
        TransactionType.CashTransfer => "تحويل نقدي",
        TransactionType.ReturnedItem => "مرتجع",
        TransactionType.AuditRequest => "طلب تدقيق",
        _ => t.ToString()
    };
}
