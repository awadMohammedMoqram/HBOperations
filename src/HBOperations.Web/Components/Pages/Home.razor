@page "/"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using HBOperations.Application.Common.Interfaces
@using HBOperations.Domain.Enums
@using Microsoft.EntityFrameworkCore
@inject IAppDbContext DbContext
@inject ICurrentUserService CurrentUser

<PageTitle>لوحة التحكم - بنك حضرموت</PageTitle>

<div class="hb-home-page">
    <!-- Welcome Banner -->
    <section class="hb-hero">
        <div class="container">
            <div class="hero-content">
                <div class="hero-logo">
                    <img src="Images/aboutLogo-fDwVp-So.svg" alt="بنك حضرموت" />
                </div>
                <h1 class="hero-title">مرحباً، @(CurrentUser.FullName ?? "مستخدم")</h1>
                <p class="hero-subtitle">
                    <i class="bi bi-shield-check"></i>
                    نظام إدارة العمليات — الإدارة العامة والفروع
                </p>
            </div>
        </div>
        <div class="hero-pattern"></div>
    </section>

    <!-- Dashboard Stats -->
    <section class="dashboard-section">
        <div class="container">
            <div class="stats-grid">
                <a href="/transactions" class="stat-card stat-total">
                    <div class="stat-icon"><i class="bi bi-archive-fill"></i></div>
                    <div class="stat-info">
                        <span class="stat-number">@_totalTransactions</span>
                        <span class="stat-label">إجمالي المعاملات</span>
                    </div>
                </a>
                <a href="/transactions?status=today" class="stat-card stat-today">
                    <div class="stat-icon"><i class="bi bi-calendar-check-fill"></i></div>
                    <div class="stat-info">
                        <span class="stat-number">@_todayTransactions</span>
                        <span class="stat-label">معاملات اليوم</span>
                    </div>
                </a>
                <a href="/transactions?status=pending" class="stat-card stat-pending">
                    <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
                    <div class="stat-info">
                        <span class="stat-number">@_pendingTransactions</span>
                        <span class="stat-label">بانتظار الاستلام</span>
                    </div>
                </a>
                <a href="/transactions?priority=urgent" class="stat-card stat-urgent">
                    <div class="stat-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <div class="stat-info">
                        <span class="stat-number">@_urgentTransactions</span>
                        <span class="stat-label">عاجلة</span>
                    </div>
                </a>
                <div class="stat-card stat-overdue">
                    <div class="stat-icon"><i class="bi bi-clock-history"></i></div>
                    <div class="stat-info">
                        <span class="stat-number">@_overdueTransactions</span>
                        <span class="stat-label">متأخرة</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Weekly Activity + Status Distribution -->
    <section class="charts-section">
        <div class="container">
            <div class="content-grid">
                <!-- Weekly Activity Chart (Last 7 days) -->
                <div class="hb-card chart-card">
                    <h3 class="card-title"><i class="bi bi-bar-chart-fill"></i> نشاط الأسبوع</h3>
                    <div class="bar-chart">
                        @{
                            var maxDayCount = _weeklyData.Values.Any() ? _weeklyData.Values.Max() : 1;
                        }
                        @foreach (var day in _weeklyData)
                        {
                            var heightPercent = maxDayCount > 0 ? (double)day.Value / maxDayCount * 100 : 0;
                            <div class="bar-column">
                                <span class="bar-value">@day.Value</span>
                                <div class="bar-fill-wrapper">
                                    <div class="bar-fill" style="height: @heightPercent.ToString("F0")%"></div>
                                </div>
                                <span class="bar-label">@day.Key</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Status Breakdown -->
                <div class="status-breakdown-card hb-card">
                    <h3 class="card-title"><i class="bi bi-pie-chart-fill"></i> توزيع الحالات</h3>
                    <div class="status-bars">
                        @foreach (var item in _statusBreakdown.OrderByDescending(x => x.Value))
                        {
                            var percent = _totalTransactions > 0 ? (double)item.Value / _totalTransactions * 100 : 0;
                            var barCls = GetStatusBarClass(item.Key);
                            var tone   = GetStatusToneClass(item.Key);
                            <div class="status-bar-item @tone">
                                <div class="status-bar-header">
                                    <span class="status-bar-label">
                                        <span class="status-bar-icon-wrap"><i class="@GetStatusIconClass(item.Key)"></i></span>
                                        @GetStatusLabel(item.Key)
                                    </span>
                                    <span class="status-bar-count">
                                        @item.Value
                                        <span class="status-bar-percent">(@percent.ToString("F0")%)</span>
                                    </span>
                                </div>
                                <div class="status-bar-track">
                                    <div class="status-bar-fill @barCls" style="width: @percent.ToString("F0")%"></div>
                                </div>
                            </div>
                        }
                        @if (!_statusBreakdown.Any())
                        {
                            <div class="empty-status">
                                <i class="bi bi-inbox"></i>
                                <p>لا توجد معاملات بعد</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Recent Transactions + Type Distribution -->
    <section class="dashboard-content">
        <div class="container">
            <div class="content-grid">
                <!-- Recent Transactions -->
                <div class="recent-transactions-card hb-card">
                    <div class="card-title-row">
                        <h3 class="card-title"><i class="bi bi-clock-history"></i> آخر المعاملات</h3>
                        <a href="/transactions" class="view-all-link">عرض الكل <i class="bi bi-arrow-left"></i></a>
                    </div>
                    @if (_recentTransactions.Any())
                    {
                        <div class="recent-list">
                            @foreach (var tx in _recentTransactions)
                            {
                                <a href="/transactions/@tx.Id" class="recent-item">
                                    <div class="recent-item-icon">
                                        <i class="bi @GetTypeIcon(tx.Type)"></i>
                                    </div>
                                    <div class="recent-item-info">
                                        <span class="recent-item-ref">@tx.ReferenceNumber</span>
                                        <span class="recent-item-subject">@tx.Subject</span>
                                    </div>
                                    <div class="recent-item-meta">
                                        <span class="hb-badge-@GetStatusBadge(tx.Status)">@GetStatusLabel(tx.Status)</span>
                                        <span class="recent-item-date">@AppTime.FormatYemen(tx.CreatedAt, "MM/dd HH:mm")</span>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-recent">
                            <i class="bi bi-file-earmark-x"></i>
                            <p>لا توجد معاملات حديثة</p>
                        </div>
                    }
                </div>

                <!-- Type Distribution -->
                <div class="hb-card chart-card">
                    <h3 class="card-title"><i class="bi bi-diagram-3-fill"></i> توزيع الأنواع</h3>
                    <div class="type-distribution">
                        @foreach (var item in _typeBreakdown.OrderByDescending(x => x.Value))
                        {
                            var percent = _totalTransactions > 0 ? (double)item.Value / _totalTransactions * 100 : 0;
                            <div class="type-item">
                                <div class="type-icon-wrap @GetTypeColorClass(item.Key)">
                                    <i class="bi @GetTypeIcon(item.Key)"></i>
                                </div>
                                <div class="type-details">
                                    <div class="type-header">
                                        <span class="type-name">@GetTypeLabel(item.Key)</span>
                                        <span class="type-count">@item.Value <small>(@percent.ToString("F0")%)</small></span>
                                    </div>
                                    <div class="type-bar-track">
                                        <div class="type-bar-fill @GetTypeColorClass(item.Key)" style="width: @percent.ToString("F0")%"></div>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (!_typeBreakdown.Any())
                        {
                            <div class="empty-status"><i class="bi bi-inbox"></i><p>لا توجد بيانات</p></div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Actions -->
    <section class="quick-actions-section">
        <div class="container">
            <h2 class="hb-section-title">إجراءات سريعة</h2>
            <div class="actions-grid">
                <a href="/transactions/create" class="action-card">
                    <div class="action-icon action-icon-primary"><i class="bi bi-plus-circle-fill"></i></div>
                    <h3>معاملة جديدة</h3>
                    <p>إنشاء معاملة جديدة</p>
                </a>
                <a href="/transactions" class="action-card">
                    <div class="action-icon action-icon-gold"><i class="bi bi-file-earmark-text-fill"></i></div>
                    <h3>المعاملات</h3>
                    <p>عرض وإدارة المعاملات</p>
                </a>
                <a href="/reports" class="action-card">
                    <div class="action-icon action-icon-purple"><i class="bi bi-graph-up-arrow"></i></div>
                    <h3>التقارير</h3>
                    <p>تقارير الأداء والفروع</p>
                </a>
                <a href="/archive" class="action-card">
                    <div class="action-icon action-icon-secondary"><i class="bi bi-archive-fill"></i></div>
                    <h3>الأرشيف</h3>
                    <p>المعاملات المؤرشفة</p>
                </a>
                <AuthorizeView Roles="SuperAdmin,ITAdmin">
                    <a href="/branches" class="action-card">
                        <div class="action-icon action-icon-success"><i class="bi bi-building"></i></div>
                        <h3>الفروع</h3>
                        <p>إدارة الفروع والمكاتب</p>
                    </a>
                    <a href="/departments" class="action-card">
                        <div class="action-icon action-icon-info"><i class="bi bi-diagram-3-fill"></i></div>
                        <h3>الأقسام</h3>
                        <p>إدارة الأقسام والإدارات</p>
                    </a>
                    <a href="/users" class="action-card">
                        <div class="action-icon action-icon-warning"><i class="bi bi-people-fill"></i></div>
                        <h3>المستخدمين</h3>
                        <p>إدارة حسابات المستخدمين</p>
                    </a>
                    <a href="/audit-log" class="action-card">
                        <div class="action-icon action-icon-danger"><i class="bi bi-clipboard-data-fill"></i></div>
                        <h3>سجل المراجعة</h3>
                        <p>سجل العمليات والتغييرات</p>
                    </a>
                </AuthorizeView>
            </div>
        </div>
    </section>

</div>

@code {
    private int _totalTransactions, _todayTransactions, _pendingTransactions, _urgentTransactions, _overdueTransactions;
    private Dictionary<TransactionStatus, int> _statusBreakdown = [];
    private Dictionary<TransactionType, int> _typeBreakdown = [];
    private Dictionary<string, int> _weeklyData = [];
    private List<HBOperations.Domain.Entities.Transaction> _recentTransactions = [];

    protected override async Task OnInitializedAsync()
    {
        var now = DateTime.UtcNow;

        // Only SuperAdmin/CEO/ITAdmin see all; everyone else sees only their personal transactions
        var globalRoles = new[] { "SuperAdmin", "CEO", "ITAdmin" };
        var hasGlobalAccess = globalRoles.Any(r => CurrentUser.IsInRole(r));

        IQueryable<HBOperations.Domain.Entities.Transaction> transactions = DbContext.Transactions.AsNoTracking();

        if (!hasGlobalAccess)
        {
            var userId = CurrentUser.UserId;
            var branchId = CurrentUser.BranchId;
            var deptId = CurrentUser.DepartmentId;
            var isDeptManager = CurrentUser.IsInRole("DepartmentManager") || CurrentUser.IsInRole("DepartmentStaff");

            // التحقق إذا كان المستخدم من إدارة الشؤون الإدارية
            var isAdminAffairs = false;
            if (deptId.HasValue)
            {
                isAdminAffairs = await DbContext.Departments.AsNoTracking()
                    .AnyAsync(d => d.Id == deptId.Value && d.Code == "DEP-ADM");
            }

            if (isAdminAffairs)
            {
                // الشؤون الإدارية: ترى كل المعاملات التي بحالة Sent/InTransit + ما شاركت فيه
                transactions = transactions.Where(t =>
                    t.Status == TransactionStatus.Sent ||
                    t.Status == TransactionStatus.InTransit ||
                    t.CreatedByUserId == userId ||
                    t.SenderUserId == userId ||
                    t.PickedUpByUserId == userId);
            }
            else if (isDeptManager && deptId.HasValue)
            {
                // DepartmentManager/Staff: see only transactions involving their department
                transactions = transactions.Where(t =>
                    t.CreatedByUserId == userId ||
                    t.SenderUserId == userId ||
                    t.ReceiverUserId == userId ||
                    t.SenderDepartmentId == deptId ||
                    t.ReceiverDepartmentId == deptId);
            }
            else
            {
                // BranchManager/Staff: see all transactions involving their branch
                transactions = transactions.Where(t =>
                    t.CreatedByUserId == userId ||
                    t.SenderUserId == userId ||
                    (branchId.HasValue && (t.SenderBranchId == branchId || t.ReceiverBranchId == branchId)) ||
                    t.ReceiverUserId == userId);
            }
        }

        _totalTransactions = await transactions.CountAsync();
        _todayTransactions = await transactions.CountAsync(t => t.CreatedAt.Date == now.Date);
        _pendingTransactions = await transactions.CountAsync(t => t.Status == TransactionStatus.Sent || t.Status == TransactionStatus.InTransit);
        _urgentTransactions = await transactions.CountAsync(t => t.Priority >= TransactionPriority.Urgent && (t.Status == TransactionStatus.Sent || t.Status == TransactionStatus.InTransit));
        _overdueTransactions = await transactions.CountAsync(t => t.DueDate.HasValue && t.DueDate < now && (t.Status == TransactionStatus.Sent || t.Status == TransactionStatus.InTransit));

        _statusBreakdown = await transactions
            .GroupBy(t => t.Status)
            .Select(g => new { Status = g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.Status, x => x.Count);

        _typeBreakdown = await transactions
            .GroupBy(t => t.Type)
            .Select(g => new { Type = g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.Type, x => x.Count);

        // Weekly data: current week starting from Saturday
        // Find the most recent Saturday (start of week)
        var today = now.Date;
        var daysSinceSaturday = ((int)today.DayOfWeek + 1) % 7; // Saturday=0 offset
        var weekStartSat = today.AddDays(-daysSinceSaturday);
        var weekEndFri = weekStartSat.AddDays(6);

        var weeklyRaw = await transactions
            .Where(t => t.CreatedAt.Date >= weekStartSat && t.CreatedAt.Date <= weekEndFri)
            .GroupBy(t => t.CreatedAt.Date)
            .Select(g => new { Date = g.Key, Count = g.Count() })
            .ToListAsync();

        // Arabic day names indexed by DayOfWeek: Sun=0..Sat=6
        var dayNames = new[] { "الأحد", "الإثنين", "الثلاثاء", "الأربعاء", "الخميس", "الجمعة", "السبت" };
        // Order: Saturday first, then Sun..Fri
        var weekOrder = new[] { DayOfWeek.Saturday, DayOfWeek.Sunday, DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday };
        _weeklyData = new Dictionary<string, int>();
        foreach (var dow in weekOrder)
        {
            var date = weekStartSat.AddDays(((int)dow + 1) % 7);
            var dayName = dayNames[(int)dow];
            var count = weeklyRaw.FirstOrDefault(x => x.Date == date)?.Count ?? 0;
            _weeklyData[dayName] = count;
        }

        _recentTransactions = await transactions
            .OrderByDescending(t => t.CreatedAt)
            .Take(8)
            .ToListAsync();
    }

    private static string GetStatusLabel(TransactionStatus s) => s switch
    {
        TransactionStatus.Sent => "بانتظار الشؤون الإدارية",
        TransactionStatus.InTransit => "قيد التوصيل",
        TransactionStatus.Received => "تم الاستلام",
        TransactionStatus.Rejected => "مرفوضة",
        TransactionStatus.Archived => "مؤرشفة",
        _ => s.ToString()
    };

    private static string GetStatusBadge(TransactionStatus s) => s switch
    {
        TransactionStatus.Sent => "warning",
        TransactionStatus.InTransit => "info",
        TransactionStatus.Received => "success",
        TransactionStatus.Rejected => "danger",
        TransactionStatus.Archived => "archived",
        _ => "secondary"
    };

    private static string GetStatusBarClass(TransactionStatus s) => s switch
    {
        TransactionStatus.Sent => "bar-warning",
        TransactionStatus.InTransit => "bar-info",
        TransactionStatus.Received => "bar-success",
        TransactionStatus.Rejected => "bar-danger",
        TransactionStatus.Archived => "bar-archived",
        _ => "bar-gray"
    };

    private static string GetStatusIconClass(TransactionStatus s) => s switch
    {
        TransactionStatus.Sent => "bi bi-send-fill",
        TransactionStatus.InTransit => "bi bi-truck",
        TransactionStatus.Received => "bi bi-check-circle-fill",
        TransactionStatus.Rejected => "bi bi-x-octagon-fill",
        TransactionStatus.Archived => "bi bi-archive-fill",
        _ => "bi bi-circle"
    };

    private static string GetStatusToneClass(TransactionStatus s) => s switch
    {
        TransactionStatus.Sent => "tone-warning",
        TransactionStatus.InTransit => "tone-info",
        TransactionStatus.Received => "tone-success",
        TransactionStatus.Rejected => "tone-danger",
        TransactionStatus.Archived => "tone-archived",
        _ => "tone-gray"
    };

    private static string GetTypeIcon(TransactionType t) => t switch
    {
        TransactionType.BranchToBranch => "bi-arrow-left-right",
        TransactionType.CashTransfer => "bi-cash-stack",
        TransactionType.DocumentDelivery => "bi-file-earmark-arrow-up",
        TransactionType.InternalDepartment => "bi-diagram-3",
        _ => "bi-file-earmark-text"
    };

    private static string GetTypeLabel(TransactionType t) => t switch
    {
        TransactionType.DocumentDelivery => "تسليم مستندات",
        TransactionType.CashTransfer => "تحويل نقدي",
        TransactionType.InternalDepartment => "داخلي بين الإدارات",
        TransactionType.BranchToBranch => "بين الفروع",
        TransactionType.Other => "أخرى",
        _ => t.ToString()
    };

    private static string GetTypeColorClass(TransactionType t) => t switch
    {
        TransactionType.DocumentDelivery => "type-color-primary",
        TransactionType.CashTransfer => "type-color-success",
        TransactionType.InternalDepartment => "type-color-warning",
        TransactionType.BranchToBranch => "type-color-info",
        TransactionType.Other => "type-color-secondary",
        _ => "type-color-secondary"
    };
}
