@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>لوحة التحكم - بنك حضرموت</PageTitle>

<div class="hb-home-page">
    <!-- Hero Section -->
    <section class="hb-hero">
        <div class="container">
            <div class="hero-content">
                <div class="hero-logo">
                    <img src="Images/aboutLogo-fDwVp-So.svg" alt="بنك حضرموت" />
                </div>
                <h1 class="hero-title">نظام إدارة العمليات</h1>
                <p class="hero-subtitle">
                    <i class="bi bi-shield-check"></i>
                    إدارة عمليات الاستلام والتسليم بين الإدارة العامة والفروع
                </p>
            </div>
        </div>
        <div class="hero-pattern"></div>
    </section>

    <!-- Services Section -->
    <section class="hb-services">
        <div class="container">
            <h2 class="hb-section-title">الخدمات المتاحة</h2>

            <div class="services-grid">
                <a href="/transactions/create" class="service-card" style="text-decoration: none;">
                    <div class="service-icon service-icon-primary">
                        <i class="bi bi-plus-circle-fill"></i>
                    </div>
                    <h3 class="service-title">معاملة جديدة</h3>
                    <p class="service-desc">إنشاء معاملة استلام أو تسليم جديدة مع إرفاق المستندات المطلوبة</p>
                    <ul class="service-features">
                        <li><i class="bi bi-check"></i> إرفاق مستندات PDF</li>
                        <li><i class="bi bi-check"></i> تحديد الفرع المستلم</li>
                        <li><i class="bi bi-check"></i> متابعة حالة المعاملة</li>
                    </ul>
                    <span class="service-link">ابدأ الآن <i class="bi bi-arrow-left"></i></span>
                </a>

                <a href="/transactions" class="service-card" style="text-decoration: none;">
                    <div class="service-icon service-icon-gold">
                        <i class="bi bi-file-earmark-text-fill"></i>
                    </div>
                    <h3 class="service-title">إدارة المعاملات</h3>
                    <p class="service-desc">عرض وإدارة جميع المعاملات الواردة والصادرة ومتابعة حالاتها</p>
                    <ul class="service-features">
                        <li><i class="bi bi-check"></i> فلترة حسب الحالة</li>
                        <li><i class="bi bi-check"></i> بحث متقدم</li>
                        <li><i class="bi bi-check"></i> تتبع سير المعاملة</li>
                    </ul>
                    <span class="service-link">عرض المعاملات <i class="bi bi-arrow-left"></i></span>
                </a>

                <a href="/branches" class="service-card" style="text-decoration: none;">
                    <div class="service-icon service-icon-success">
                        <i class="bi bi-building"></i>
                    </div>
                    <h3 class="service-title">الفروع والمكاتب</h3>
                    <p class="service-desc">عرض الهيكل التنظيمي للفروع والمكاتب والإدارات</p>
                    <ul class="service-features">
                        <li><i class="bi bi-check"></i> الإدارة العامة</li>
                        <li><i class="bi bi-check"></i> الفروع الرئيسية</li>
                        <li><i class="bi bi-check"></i> المكاتب</li>
                    </ul>
                    <span class="service-link">عرض الفروع <i class="bi bi-arrow-left"></i></span>
                </a>

                <AuthorizeView Roles="SuperAdmin,ITAdmin">
                    <a href="/users" class="service-card" style="text-decoration: none;">
                        <div class="service-icon service-icon-info">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <h3 class="service-title">إدارة المستخدمين</h3>
                        <p class="service-desc">إدارة حسابات المستخدمين والصلاحيات والأدوار</p>
                        <ul class="service-features">
                            <li><i class="bi bi-check"></i> إضافة مستخدمين</li>
                            <li><i class="bi bi-check"></i> تحديد الصلاحيات</li>
                            <li><i class="bi bi-check"></i> إدارة الأدوار</li>
                        </ul>
                        <span class="service-link">إدارة المستخدمين <i class="bi bi-arrow-left"></i></span>
                    </a>

                    <a href="/audit-log" class="service-card" style="text-decoration: none;">
                        <div class="service-icon service-icon-warning">
                            <i class="bi bi-clipboard-data"></i>
                        </div>
                        <h3 class="service-title">سجل المراجعة</h3>
                        <p class="service-desc">عرض سجل شامل لجميع العمليات والأنشطة في النظام</p>
                        <ul class="service-features">
                            <li><i class="bi bi-check"></i> تتبع العمليات</li>
                            <li><i class="bi bi-check"></i> فلترة حسب التاريخ</li>
                            <li><i class="bi bi-check"></i> مراقبة الأمان</li>
                        </ul>
                        <span class="service-link">عرض السجلات <i class="bi bi-arrow-left"></i></span>
                    </a>
                </AuthorizeView>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="hb-features">
        <div class="container">
            <h2 class="hb-section-title">لماذا تختار خدماتنا الإلكترونية؟</h2>

            <div class="features-grid">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h4>أمان عالي</h4>
                    <p>حماية بياناتك بأحدث تقنيات التشفير</p>
                </div>

                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bi bi-clock"></i>
                    </div>
                    <h4>متاح 24/7</h4>
                    <p>خدماتنا متاحة في أي وقت ومن أي مكان</p>
                </div>

                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bi bi-lightning-charge"></i>
                    </div>
                    <h4>سرعة في الإنجاز</h4>
                    <p>معاملاتك فورية للمعاملات</p>
                </div>

                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bi bi-phone"></i>
                    </div>
                    <h4>سهولة الاستخدام</h4>
                    <p>واجهة مستخدم بسيطة وسهلة على جميع الأجهزة</p>
                </div>
            </div>
        </div>
    </section>
</div>
