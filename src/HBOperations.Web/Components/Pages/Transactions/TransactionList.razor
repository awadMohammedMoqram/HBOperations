@page "/transactions"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using HBOperations.Application.Common.Interfaces
@using HBOperations.Application.Workflow
@using HBOperations.Domain.Enums
@using HBOperations.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject IAppDbContext DbContext
@inject ICurrentUserService CurrentUser
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject TransactionStateMachine StateMachine
@inject INotificationService NotificationService

<PageTitle>المعاملات - بنك حضرموت</PageTitle>

<div class="page-container hb-fade-in">
    <!-- Page Header -->
    <div class="page-title-section">
        <div class="title-with-action">
            <div>
                <h1 class="section-title"><i class="bi bi-file-earmark-text"></i> إدارة المعاملات</h1>
                <p class="section-subtitle">عرض وإدارة جميع المعاملات الواردة والصادرة</p>
            </div>
            <a href="/transactions/create" class="btn-hb-primary btn-add-transaction">
                <i class="bi bi-plus-circle"></i> معاملة جديدة
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="hb-card filter-card">
        <div class="filters-row">
            <div class="filter-group">
                <label class="hb-form-label">بحث</label>
                <input type="text" class="hb-form-control" placeholder="رقم المرجع أو الموضوع..."
                       @bind="_searchTerm" @bind:event="oninput" />
            </div>
            <div class="filter-group">
                <label class="hb-form-label">الحالة</label>
                <select class="hb-form-control" @bind="_statusFilter">
                    <option value="">الكل</option>
                    @foreach (var status in Enum.GetValues<TransactionStatus>())
                    {
                        <option value="@status">@GetStatusLabel(status)</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label class="hb-form-label">النوع</label>
                <select class="hb-form-control" @bind="_typeFilter">
                    <option value="">الكل</option>
                    @foreach (var type in Enum.GetValues<TransactionType>())
                    {
                        <option value="@type">@GetTypeLabel(type)</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label class="hb-form-label">الأولوية</label>
                <select class="hb-form-control" @bind="_priorityFilter">
                    <option value="">الكل</option>
                    @foreach (var priority in Enum.GetValues<TransactionPriority>())
                    {
                        <option value="@priority">@GetPriorityLabel(priority)</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar">
        <div class="stat-item">
            <i class="bi bi-file-earmark-text"></i>
            <span class="stat-number">@_totalCount</span>
            <span class="stat-label">إجمالي</span>
        </div>
        <div class="stat-item stat-pending">
            <i class="bi bi-send"></i>
            <span class="stat-number">@_pendingCount</span>
            <span class="stat-label">بانتظار الاستلام</span>
        </div>
        <div class="stat-item stat-completed">
            <i class="bi bi-check-circle"></i>
            <span class="stat-number">@_completedCount</span>
            <span class="stat-label">مستلمة / مؤرشفة</span>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="hb-alert hb-alert-success">
            <i class="bi bi-check-circle-fill"></i> @_successMessage
        </div>
    }

    <!-- Table -->
    @if (_loading)
    {
        <div class="hb-loading">
            <div class="hb-spinner"></div>
            <span>جاري تحميل المعاملات...</span>
        </div>
    }
    else if (!_transactions.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h3>لا توجد معاملات</h3>
            <p>لم يتم العثور على معاملات تطابق معايير البحث</p>
        </div>
    }
    else
    {
        <div class="table-container">
            <table class="hb-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>رقم المرجع</th>
                        <th>الموضوع</th>
                        <th>النوع</th>
                        <th>من</th>
                        <th>إلى</th>
                        <th>الأولوية</th>
                        <th>الحالة</th>
                        <th>التاريخ</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var index = 0; }
                    @foreach (var t in GetFilteredTransactions())
                    {
                        index++;
                        <tr>
                            <td>@index</td>
                            <td><span class="ref-number">@t.ReferenceNumber</span></td>
                            <td class="subject-cell">@t.Subject</td>
                            <td><span class="hb-badge hb-badge-primary">@GetTypeLabel(t.Type)</span></td>
                            <td>@(t.SenderBranch?.NameAr ?? "—")</td>
                            <td>@(t.ReceiverBranch?.NameAr ?? "—")</td>
                            <td>
                                <span class="hb-badge priority-badge @GetPriorityBadgeClass(t.Priority)">
                                    <i class="@GetPriorityIcon(t.Priority)"></i>
                                    <span>@GetPriorityLabel(t.Priority)</span>
                                </span>
                            </td>
                            <td>
                                <span class="status-badge @GetStatusClass(t.Status)">
                                    <i class="@GetStatusIcon(t.Status)"></i>
                                    @GetStatusLabel(t.Status)
                                </span>
                            </td>
                            <td class="date-cell">@t.CreatedAt.ToString("yyyy/MM/dd")</td>
                            <td>
                                <div class="action-buttons">
                                    <a href="/transactions/@t.Id" class="action-btn view" title="عرض التفاصيل">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @{
                                        var isReceiverOnly = IsReceiverOnly(t);
                                        var isSender = IsSenderFor(t);
                                        var canEdit = isSender && t.Status is not (TransactionStatus.Cancelled or TransactionStatus.Archived or TransactionStatus.Received or TransactionStatus.Rejected);
                                        var canReject = isReceiverOnly && t.Status == TransactionStatus.Sent;
                                    }
                                    @if (canEdit)
                                    {
                                        <a href="/transactions/edit/@t.Id" class="action-btn edit" title="تعديل">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                    }
                                    @if (canReject)
                                    {
                                        <button class="action-btn reject" title="رفض المعاملة" @onclick="() => OpenRejectModal(t)">
                                            <i class="bi bi-x-octagon"></i>
                                        </button>
                                    }
                                    @if (isSender)
                                    {
                                        <button class="action-btn delete" title="حذف" @onclick="() => OpenDeleteModal(t)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Pagination *@
        @if (_totalPages > 1)
        {
            <div class="pagination-container">
                <div class="pagination-info">
                    عرض @((_currentPage - 1) * _pageSize + 1) - @Math.Min(_currentPage * _pageSize, _filteredCount) من @_filteredCount
                </div>
                <div class="pagination-controls">
                    <button class="page-btn" disabled="@(_currentPage <= 1)" @onclick="() => GoToPage(1)">
                        <i class="bi bi-chevron-double-right"></i>
                    </button>
                    <button class="page-btn" disabled="@(_currentPage <= 1)" @onclick="() => GoToPage(_currentPage - 1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                    @foreach (var p in GetPageNumbers())
                    {
                        <button class="page-btn @(p == _currentPage ? "active" : "")" @onclick="() => GoToPage(p)">@p</button>
                    }
                    <button class="page-btn" disabled="@(_currentPage >= _totalPages)" @onclick="() => GoToPage(_currentPage + 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <button class="page-btn" disabled="@(_currentPage >= _totalPages)" @onclick="() => GoToPage(_totalPages)">
                        <i class="bi bi-chevron-double-left"></i>
                    </button>
                </div>
            </div>
        }
    }
</div>

@* ===== Delete Confirmation Modal ===== *@
@if (_showDeleteModal)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="modal-content modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header modal-header-danger">
                <h3><i class="bi bi-exclamation-triangle"></i> تأكيد الحذف</h3>
                <button class="modal-close" @onclick="CloseDeleteModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_deleteError))
                {
                    <div class="hb-alert hb-alert-danger" style="margin-bottom:1rem;">
                        <i class="bi bi-exclamation-triangle-fill"></i> @_deleteError
                    </div>
                }
                <p class="delete-message">هل أنت متأكد من حذف المعاملة <strong>@_deletingTransaction?.ReferenceNumber</strong>؟</p>
                <p class="delete-subject">@_deletingTransaction?.Subject</p>
                <p class="delete-warning"><i class="bi bi-info-circle"></i> سيتم حذف جميع المستندات والملاحظات المرتبطة بها.</p>
            </div>
            <div class="modal-footer">
                <button class="btn-hb-danger" @onclick="HandleDelete" disabled="@_deleting">
                    @if (_deleting)
                    {
                        <span class="hb-spinner" style="width:18px;height:18px;border-width:2px;"></span>
                    }
                    <i class="bi bi-trash3"></i> حذف
                </button>
                <button class="btn-hb-outline" @onclick="CloseDeleteModal">إلغاء</button>
            </div>
        </div>
    </div>
}

@* ===== Reject Confirmation Modal ===== *@
@if (_showRejectModal)
{
    <div class="modal-overlay" @onclick="CloseRejectModal">
        <div class="modal-content modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header modal-header-danger">
                <h3><i class="bi bi-x-octagon"></i> رفض المعاملة</h3>
                <button class="modal-close" @onclick="CloseRejectModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_rejectError))
                {
                    <div class="hb-alert hb-alert-danger" style="margin-bottom:1rem;">
                        <i class="bi bi-exclamation-triangle-fill"></i> @_rejectError
                    </div>
                }
                <p class="delete-message">رفض المعاملة <strong>@_rejectingTransaction?.ReferenceNumber</strong></p>
                <p class="delete-subject">@_rejectingTransaction?.Subject</p>
                <div class="hb-form-group" style="margin-top:1rem;">
                    <label class="hb-form-label">سبب الرفض <span class="required-star">*</span></label>
                    <textarea class="hb-form-control note-textarea" rows="6" maxlength="1000"
                              placeholder="اكتب سبب رفض المعاملة بشكل واضح..."
                              @bind="_rejectionNote" @bind:event="oninput"></textarea>
                    <small class="hb-form-help">سيتم إشعار المرسل بسبب الرفض.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-hb-danger" @onclick="ConfirmReject"
                        disabled="@(_rejecting || string.IsNullOrWhiteSpace(_rejectionNote))">
                    @if (_rejecting)
                    {
                        <span class="hb-spinner" style="width:18px;height:18px;border-width:2px;"></span>
                    }
                    <i class="bi bi-x-octagon"></i> تأكيد الرفض
                </button>
                <button class="btn-hb-outline" @onclick="CloseRejectModal">تراجع</button>
            </div>
        </div>
    </div>
}

@code {
    private List<HBOperations.Domain.Entities.Transaction> _transactions = [];
    private bool _loading = true;
    private string _searchTerm = "";
    private string _statusFilter = "";
    private string _typeFilter = "";
    private string _priorityFilter = "";
    private int _totalCount, _pendingCount, _inTransitCount, _completedCount;
    private int _currentPage = 1;
    private int _pageSize = 15;
    private int _filteredCount;
    private int _totalPages;

    // Delete modal state
    private bool _showDeleteModal, _deleting;
    private string? _deleteError, _successMessage;
    private HBOperations.Domain.Entities.Transaction? _deletingTransaction;

    // Reject modal state
    private bool _showRejectModal, _rejecting;
    private string? _rejectError;
    private string? _rejectionNote;
    private HBOperations.Domain.Entities.Transaction? _rejectingTransaction;

    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessFromQuery { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(SuccessFromQuery))
            _successMessage = SuccessFromQuery;

        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        // Only SuperAdmin/CEO/ITAdmin see all; everyone else sees only their personal transactions
        var globalRoles = new[] { "SuperAdmin", "CEO", "ITAdmin" };
        var hasGlobalAccess = globalRoles.Any(r => CurrentUser.IsInRole(r));

        IQueryable<HBOperations.Domain.Entities.Transaction> query = DbContext.Transactions
            .Include(t => t.SenderBranch)
            .Include(t => t.ReceiverBranch);

        if (!hasGlobalAccess)
        {
            var userId = CurrentUser.UserId;
            var branchId = CurrentUser.BranchId;
            var deptId = CurrentUser.DepartmentId;

            query = query.Where(t =>
                t.CreatedByUserId == userId ||
                t.SenderUserId == userId ||
                (branchId.HasValue && (t.SenderBranchId == branchId || t.ReceiverBranchId == branchId)) ||
                t.ReceiverUserId == userId || (deptId.HasValue && t.SenderDepartmentId == deptId));
        }

        _transactions = await query
            .OrderByDescending(t => t.CreatedAt)
            .ToListAsync();

        _totalCount = _transactions.Count;
        _pendingCount = _transactions.Count(t => t.Status == TransactionStatus.Sent);
        _inTransitCount = _transactions.Count(t => t.Status == TransactionStatus.Sent);
        _completedCount = _transactions.Count(t => t.Status is TransactionStatus.Received or TransactionStatus.Archived);
        _loading = false;
    }

    private void OpenDeleteModal(HBOperations.Domain.Entities.Transaction tx)
    {
        _deletingTransaction = tx;
        _deleteError = null;
        _showDeleteModal = true;
    }

    private async Task HandleDelete()
    {
        _deleting = true;
        _deleteError = null;
        try
        {
            DbContext.Transactions.Remove(_deletingTransaction!);
            await DbContext.SaveChangesAsync();
            _successMessage = $"تم حذف المعاملة «{_deletingTransaction!.ReferenceNumber}» بنجاح";
            _showDeleteModal = false;
            await LoadTransactions();
        }
        catch (Exception ex)
        {
            _deleteError = $"حدث خطأ: {ex.Message}";
        }
        finally { _deleting = false; }
    }

    private void CloseDeleteModal() { _showDeleteModal = false; _deleteError = null; }

    // ===== Receiver / Sender helpers =====
    private bool IsSenderFor(HBOperations.Domain.Entities.Transaction t)
        => t.SenderUserId == CurrentUser.UserId || t.CreatedByUserId == CurrentUser.UserId;

    private bool IsReceiverOnly(HBOperations.Domain.Entities.Transaction t)
    {
        if (IsSenderFor(t)) return false;
        return TransactionStateMachine.IsAuthorizedReceiver(t, CurrentUser.UserId, CurrentUser.BranchId, CurrentUser.DepartmentId);
    }

    // ===== Reject flow =====
    private void OpenRejectModal(HBOperations.Domain.Entities.Transaction tx)
    {
        _rejectingTransaction = tx;
        _rejectError = null;
        _rejectionNote = null;
        _showRejectModal = true;
    }

    private void CloseRejectModal()
    {
        if (_rejecting) return;
        _showRejectModal = false;
        _rejectError = null;
        _rejectionNote = null;
    }

    private async Task ConfirmReject()
    {
        if (_rejectingTransaction is null || string.IsNullOrWhiteSpace(_rejectionNote)) return;
        _rejecting = true; _rejectError = null;
        try
        {
            var tracked = await DbContext.Transactions
                .Include(t => t.History)
                .FirstOrDefaultAsync(t => t.Id == _rejectingTransaction.Id);
            if (tracked is null) { _rejectError = "المعاملة غير موجودة"; return; }

            var result = StateMachine.TransitionTo(
                tracked, TransactionStatus.Rejected,
                CurrentUser.UserId, CurrentUser.BranchId, CurrentUser.DepartmentId, CurrentUser.Roles,
                _rejectionNote.Trim());
            if (!result.IsSuccess) { _rejectError = result.Error; return; }

            await DbContext.SaveChangesAsync();

            try
            {
                if (tracked.SenderUserId != CurrentUser.UserId)
                {
                    await NotificationService.NotifyUserAsync(
                        tracked.SenderUserId,
                        $"رفض المعاملة {tracked.ReferenceNumber}",
                        $"رفض المستلم المعاملة. السبب: {_rejectionNote!.Trim()}",
                        tracked.Id,
                        NotificationType.TransactionStatusChanged);
                }
            }
            catch { /* notification failure must not block */ }

            _successMessage = $"تم رفض المعاملة «{tracked.ReferenceNumber}» وإشعار المرسل";
            _showRejectModal = false;
            _rejectionNote = null;
            await LoadTransactions();
        }
        catch (Exception ex) { _rejectError = $"حدث خطأ: {ex.Message}"; }
        finally { _rejecting = false; }
    }

    private IEnumerable<HBOperations.Domain.Entities.Transaction> GetFilteredTransactions()
    {
        var query = _transactions.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchTerm))
            query = query.Where(t => t.ReferenceNumber.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
                || t.Subject.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));

        if (Enum.TryParse<TransactionStatus>(_statusFilter, out var status))
            query = query.Where(t => t.Status == status);

        if (Enum.TryParse<TransactionType>(_typeFilter, out var type))
            query = query.Where(t => t.Type == type);

        if (Enum.TryParse<TransactionPriority>(_priorityFilter, out var priority))
            query = query.Where(t => t.Priority == priority);

        var filtered = query.ToList();
        _filteredCount = filtered.Count;
        _totalPages = (int)Math.Ceiling((double)_filteredCount / _pageSize);
        if (_currentPage > _totalPages && _totalPages > 0) _currentPage = _totalPages;

        return filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    }

    private void GoToPage(int page)
    {
        _currentPage = Math.Max(1, Math.Min(page, _totalPages));
    }

    private IEnumerable<int> GetPageNumbers()
    {
        var start = Math.Max(1, _currentPage - 2);
        var end = Math.Min(_totalPages, start + 4);
        start = Math.Max(1, end - 4);
        return Enumerable.Range(start, end - start + 1);
    }

    private static string GetStatusLabel(TransactionStatus s) => s switch
    {
        TransactionStatus.Sent => "بانتظار الاستلام",
        TransactionStatus.Received => "تم الاستلام",
        TransactionStatus.Rejected => "مرفوضة",
        TransactionStatus.Cancelled => "ملغاة",
        TransactionStatus.Archived => "مؤرشفة",
        _ => s.ToString()
    };

    private static string GetTypeLabel(TransactionType t) => t switch
    {
        TransactionType.DocumentDelivery => "تسليم مستندات",
        TransactionType.CashTransfer => "تحويل نقدي",
        TransactionType.InternalDepartment => "داخلي بين الإدارات",
        TransactionType.BranchToBranch => "بين الفروع",
        TransactionType.Other => "أخرى",
        _ => t.ToString()
    };

    private static string GetPriorityLabel(TransactionPriority p) => p switch
    {
        TransactionPriority.Normal => "عادية",
        TransactionPriority.Important => "مهمة",
        TransactionPriority.Urgent => "عاجلة",
        _ => p.ToString()
    };

    private static string GetStatusClass(TransactionStatus s) => s switch
    {
        TransactionStatus.Sent => "status-pending",
        TransactionStatus.Received => "status-confirmed",
        TransactionStatus.Rejected => "status-returned",
        TransactionStatus.Cancelled => "status-cancelled",
        TransactionStatus.Archived => "status-archived",
        _ => ""
    };

    private static string GetStatusIcon(TransactionStatus s) => s switch
    {
        TransactionStatus.Sent => "bi bi-send",
        TransactionStatus.Received => "bi bi-check-circle-fill",
        TransactionStatus.Rejected => "bi bi-x-octagon",
        TransactionStatus.Cancelled => "bi bi-x-circle",
        TransactionStatus.Archived => "bi bi-archive",
        _ => "bi bi-circle"
    };

    private static string GetPriorityBadgeClass(TransactionPriority p) => p switch
    {
        TransactionPriority.Normal => "hb-badge-success",
        TransactionPriority.Important => "hb-badge-info",
        TransactionPriority.Urgent => "hb-badge-danger",
        _ => "hb-badge-secondary"
    };

    private static string GetPriorityIcon(TransactionPriority p) => p switch
    {
        TransactionPriority.Normal => "bi bi-flag-fill",
        TransactionPriority.Important => "bi bi-exclamation-circle-fill",
        TransactionPriority.Urgent => "bi bi-lightning-fill",
        _ => "bi bi-flag"
    };
}
