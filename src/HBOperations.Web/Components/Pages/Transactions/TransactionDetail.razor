@page "/transactions/{Id:guid}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using HBOperations.Application.Common.Interfaces
@using HBOperations.Application.Workflow
@using HBOperations.Domain.Enums
@using HBOperations.Domain.Entities
@using HBOperations.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ICurrentUserService CurrentUser
@inject INotificationService NotificationService
@inject IEmailService EmailService
@inject NavigationManager Navigation

<PageTitle>تفاصيل المعاملة - بنك حضرموت</PageTitle>

<div class="page-container hb-fade-in">
    @if (_loading)
    {
        <div class="hb-loading"><div class="hb-spinner"></div><span>جاري تحميل البيانات...</span></div>
    }
    else if (_transaction is null)
    {
        <div class="not-found">
            <i class="bi bi-file-earmark-x"></i>
            <h2>المعاملة غير موجودة</h2>
            <p>لم يتم العثور على معاملة بهذا المعرّف</p>
            <a href="/transactions" class="btn-hb-primary"><i class="bi bi-arrow-right"></i> العودة للمعاملات</a>
        </div>
    }
    else
    {
        <!-- Page Header -->
        <div class="page-title-section">
            <div class="title-with-action">
                <div>
                    <h1 class="section-title">
                        <i class="bi bi-file-earmark-text"></i>
                        المعاملة: <span class="ref-number">@_transaction.ReferenceNumber</span>
                    </h1>
                    <p class="section-subtitle">@_transaction.Subject</p>
                </div>
                <div class="title-actions">
                    <a href="/transactions/edit/@_transaction.Id" class="btn-hb-outline"><i class="bi bi-pencil-square"></i> تعديل</a>
                    <a href="/transactions" class="btn-hb-outline"><i class="bi bi-arrow-right"></i> العودة</a>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="hb-alert hb-alert-success">
                <i class="bi bi-check-circle-fill"></i> @_successMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="hb-alert hb-alert-danger">
                <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
            </div>
        }

        <!-- Workflow Progress -->
        <div class="workflow-progress">
            @{
                var mainSteps = new[] {
                    TransactionStatus.Draft,
                    TransactionStatus.PendingReview,
                    TransactionStatus.Approved,
                    TransactionStatus.InTransit,
                    TransactionStatus.Received,
                    TransactionStatus.Confirmed,
                    TransactionStatus.Archived
                };
                var currentIndex = Array.IndexOf(mainSteps, _transaction.Status);
                var isTerminal = _transaction.Status is TransactionStatus.Cancelled or TransactionStatus.Returned or TransactionStatus.Disputed;
            }
            @for (var i = 0; i < mainSteps.Length; i++)
            {
                var step = mainSteps[i];
                var stepClass = "step-upcoming";
                if (isTerminal && step == _transaction.Status) stepClass = "step-current";
                else if (!isTerminal && i < currentIndex) stepClass = "step-completed";
                else if (!isTerminal && i == currentIndex) stepClass = "step-current";

                <div class="workflow-step @stepClass">
                    <div class="step-dot">
                        @if (stepClass == "step-completed")
                        {
                            <i class="bi bi-check-lg"></i>
                        }
                        else
                        {
                            <span>@(i + 1)</span>
                        }
                    </div>
                    <span class="step-label">@GetStatusLabel(step)</span>
                    @if (i < mainSteps.Length - 1)
                    {
                        <div class="step-line @(stepClass == "step-completed" ? "line-completed" : "")"></div>
                    }
                </div>
            }
            @if (isTerminal)
            {
                <div class="workflow-step step-terminal">
                    <div class="step-dot">
                        <i class="bi @GetStatusIcon(_transaction.Status)"></i>
                    </div>
                    <span class="step-label">@GetStatusLabel(_transaction.Status)</span>
                </div>
            }
        </div>

        <!-- Status Bar -->
        <div class="status-bar">
            <div class="status-current">
                <span class="status-badge-lg @GetStatusCssClass(_transaction.Status)">
                    <i class="bi @GetStatusIcon(_transaction.Status)"></i>
                    @GetStatusLabel(_transaction.Status)
                </span>
            </div>
            <div class="status-meta">
                <span><i class="bi bi-calendar3"></i> @_transaction.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
                @if (_transaction.DueDate.HasValue)
                {
                    var isOverdue = _transaction.DueDate < DateTime.UtcNow && _transaction.Status != TransactionStatus.Confirmed && _transaction.Status != TransactionStatus.Archived;
                    <span class="@(isOverdue ? "overdue-text" : "")">
                        <i class="bi bi-alarm"></i> الاستحقاق: @_transaction.DueDate.Value.ToString("yyyy/MM/dd")
                        @if (isOverdue) { <span class="overdue-badge">متأخرة</span> }
                    </span>
                }
            </div>
        </div>

        <!-- Action Buttons -->
        @if (_allowedTransitions.Any())
        {
            <div class="hb-card action-card">
                <h3 class="card-section-title"><i class="bi bi-lightning-fill"></i> الإجراءات المتاحة</h3>
                <div class="action-note-input">
                    <label class="hb-form-label">ملاحظة الإجراء (اختياري)</label>
                    <input type="text" class="hb-form-control" placeholder="أضف ملاحظة مع الإجراء..."
                           @bind="_actionNotes" />
                </div>
                <div class="workflow-actions">
                    @foreach (var target in _allowedTransitions)
                    {
                        <button class="workflow-btn @GetActionBtnClass(target)"
                                @onclick="() => HandleTransition(target)" disabled="@_processing">
                            @if (_processing)
                            {
                                <span class="hb-spinner" style="width:16px;height:16px;border-width:2px;"></span>
                            }
                            else
                            {
                                <i class="bi @GetStatusIcon(target)"></i>
                            }
                            @GetActionLabel(target)
                        </button>
                    }
                </div>
            </div>
        }

        <!-- Info Cards Grid -->
        <div class="detail-grid">
            <!-- Main Info -->
            <div class="hb-card detail-card">
                <h3 class="card-section-title"><i class="bi bi-info-circle"></i> معلومات المعاملة</h3>
                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">رقم المرجع</span>
                        <span class="info-value ref-mono">@_transaction.ReferenceNumber</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">النوع</span>
                        <span class="info-value">@GetTypeLabel(_transaction.Type)</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">الأولوية</span>
                        <span class="info-value">
                            <span class="priority-dot @GetPriorityClass(_transaction.Priority)"></span>
                            @GetPriorityLabel(_transaction.Priority)
                        </span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">تاريخ الإنشاء</span>
                        <span class="info-value">@_transaction.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_transaction.Description))
                {
                    <div class="description-block">
                        <span class="info-label">الوصف</span>
                        <p>@_transaction.Description</p>
                    </div>
                }
            </div>

            <!-- Sender / Receiver -->
            <div class="hb-card detail-card">
                <h3 class="card-section-title"><i class="bi bi-arrow-left-right"></i> المرسل والمستلم</h3>
                <div class="sender-receiver">
                    <div class="sr-box sr-sender">
                        <div class="sr-icon"><i class="bi bi-arrow-up-left-circle"></i></div>
                        <h4>المرسل</h4>
                        <p class="sr-branch">@(_transaction.SenderBranch?.NameAr ?? "—")</p>
                        @if (_transaction.SenderDepartment != null)
                        {
                            <p class="sr-dept">@_transaction.SenderDepartment.NameAr</p>
                        }
                    </div>
                    <div class="sr-arrow"><i class="bi bi-arrow-left"></i></div>
                    <div class="sr-box sr-receiver">
                        <div class="sr-icon"><i class="bi bi-arrow-down-right-circle"></i></div>
                        <h4>المستلم</h4>
                        <p class="sr-branch">@(_transaction.ReceiverBranch?.NameAr ?? "—")</p>
                        @if (_transaction.ReceiverDepartment != null)
                        {
                            <p class="sr-dept">@_transaction.ReceiverDepartment.NameAr</p>
                        }
                    </div>
                </div>
                <div class="dates-row">
                    @if (_transaction.SentAt.HasValue)
                    {
                        <div class="date-item"><span class="info-label">تاريخ الإرسال</span><span>@_transaction.SentAt.Value.ToString("yyyy/MM/dd HH:mm")</span></div>
                    }
                    @if (_transaction.ReceivedAt.HasValue)
                    {
                        <div class="date-item"><span class="info-label">تاريخ الاستلام</span><span>@_transaction.ReceivedAt.Value.ToString("yyyy/MM/dd HH:mm")</span></div>
                    }
                    @if (_transaction.CompletedAt.HasValue)
                    {
                        <div class="date-item"><span class="info-label">تاريخ الإنجاز</span><span>@_transaction.CompletedAt.Value.ToString("yyyy/MM/dd HH:mm")</span></div>
                    }
                </div>
            </div>
        </div>

        <!-- Documents -->
        <div class="hb-card detail-card">
            <h3 class="card-section-title"><i class="bi bi-paperclip"></i> المستندات (@_transaction.Documents.Count)</h3>
            
            <!-- Upload Zone -->
            <HBOperations.Web.Components.Shared.FileUploadZone 
                TransactionId="@_transaction.Id" 
                OnUploadCompleted="ReloadDocuments" />

            @if (_transaction.Documents.Any())
            {
                <div class="documents-list">
                    @foreach (var doc in _transaction.Documents.OrderByDescending(d => d.UploadedAt))
                    {
                        <div class="doc-item">
                            <div class="doc-icon"><i class="bi bi-file-earmark-pdf"></i></div>
                            <div class="doc-info">
                                <span class="doc-name">@doc.OriginalFileName</span>
                                <span class="doc-meta">@GetDocTypeName(doc.DocumentType) — @FormatFileSize(doc.FileSizeBytes) — v@(doc.Version)</span>
                            </div>
                            <span class="doc-date">@doc.UploadedAt.ToString("yyyy/MM/dd")</span>
                            <div class="doc-actions">
                                <button class="doc-action-btn" title="معاينة" @onclick="() => PreviewDocument(doc.Id)">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <a href="/api/documents/@doc.Id/download" target="_blank" class="doc-action-btn" title="تحميل">
                                    <i class="bi bi-download"></i>
                                </a>
                                <button class="doc-action-btn doc-action-delete" title="حذف" @onclick="() => OpenDeleteDocModal(doc)">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="empty-text">لا توجد مستندات مرفقة — استخدم منطقة الرفع أعلاه</p>
            }
        </div>

        <!-- PDF Preview Modal -->
        @if (_previewDocId.HasValue)
        {
            var previewDoc = _transaction?.Documents.FirstOrDefault(d => d.Id == _previewDocId);
            <div class="modal-overlay" @onclick="ClosePreview" @onkeydown="HandlePreviewKeyDown" tabindex="0">
                <div class="modal-content pdf-modal @(_pdfFullscreen ? "pdf-fullscreen" : "")" @onclick:stopPropagation="true">
                    <div class="modal-header pdf-header">
                        <div class="pdf-header-info">
                            <i class="bi bi-file-earmark-pdf pdf-icon-lg"></i>
                            <div>
                                <h3>@(previewDoc?.OriginalFileName ?? "معاينة المستند")</h3>
                                @if (previewDoc is not null)
                                {
                                    <span class="pdf-meta-text">@GetDocTypeName(previewDoc.DocumentType) — @FormatFileSize(previewDoc.FileSizeBytes) — الإصدار @(previewDoc.Version)</span>
                                }
                            </div>
                        </div>
                        <div class="pdf-toolbar">
                            <a href="/api/documents/@_previewDocId/download" target="_blank" class="pdf-tool-btn" title="تحميل الملف">
                                <i class="bi bi-download"></i>
                            </a>
                            <a href="/api/documents/@_previewDocId/preview" target="_blank" class="pdf-tool-btn" title="فتح في نافذة جديدة">
                                <i class="bi bi-box-arrow-up-left"></i>
                            </a>
                            <button class="pdf-tool-btn" @onclick="TogglePdfFullscreen" title="@(_pdfFullscreen ? "تصغير" : "ملء الشاشة")">
                                <i class="bi @(_pdfFullscreen ? "bi-fullscreen-exit" : "bi-arrows-fullscreen")"></i>
                            </button>
                            <button class="modal-close" @onclick="ClosePreview" title="إغلاق (Esc)">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>
                    <div class="modal-body pdf-body">
                        <div class="pdf-loading-overlay" id="pdfLoader">
                            <div class="hb-spinner"></div>
                            <span>جاري تحميل المستند...</span>
                        </div>
                        <iframe src="/api/documents/@_previewDocId/preview" class="pdf-frame" onload="document.getElementById('pdfLoader').style.display='none'"></iframe>
                    </div>
                </div>
            </div>
        }

        <!-- Delete Document Confirmation Modal -->
        @if (_deleteDoc is not null)
        {
            <div class="modal-overlay" @onclick="() => _deleteDoc = null">
                <div class="modal-content" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h3><i class="bi bi-trash3"></i> حذف مستند</h3>
                        <button class="modal-close" @onclick="() => _deleteDoc = null"><i class="bi bi-x-lg"></i></button>
                    </div>
                    <div class="modal-body">
                        <p>هل أنت متأكد من حذف المستند <strong>@_deleteDoc.OriginalFileName</strong>؟</p>
                        <p class="text-muted">لا يمكن التراجع عن هذا الإجراء.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-hb-outline" @onclick="() => _deleteDoc = null">إلغاء</button>
                        <button class="btn-hb-danger" @onclick="DeleteDocument">
                            <i class="bi bi-trash3"></i> حذف
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- History Timeline -->
        <div class="hb-card detail-card">
            <h3 class="card-section-title"><i class="bi bi-clock-history"></i> سجل الحركات (@_transaction.History.Count)</h3>
            @if (_transaction.History.Any())
            {
                <div class="timeline">
                    @foreach (var h in _transaction.History.OrderByDescending(x => x.PerformedAt))
                    {
                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <span class="timeline-action">@h.Action</span>
                                    <span class="timeline-date">@h.PerformedAt.ToString("yyyy/MM/dd HH:mm")</span>
                                </div>
                                <div class="timeline-status">
                                    <span class="status-mini @GetStatusCssClass(h.FromStatus)">@GetStatusLabel(h.FromStatus)</span>
                                    <i class="bi bi-arrow-left"></i>
                                    <span class="status-mini @GetStatusCssClass(h.ToStatus)">@GetStatusLabel(h.ToStatus)</span>
                                </div>
                                @if (!string.IsNullOrEmpty(h.Notes))
                                {
                                    <p class="timeline-notes">@h.Notes</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="empty-text">لا يوجد سجل حركات بعد</p>
            }
        </div>

        <!-- Notes -->
        <div class="hb-card detail-card">
            <h3 class="card-section-title"><i class="bi bi-chat-left-text"></i> الملاحظات (@_transaction.Notes.Count)</h3>

            <!-- Add Note Form -->
            <div class="add-note-form">
                <div class="note-input-row">
                    <input type="text" class="hb-form-control" placeholder="اكتب ملاحظة..."
                           @bind="_newNote" @onkeydown="HandleNoteKeyDown" />
                    <button class="btn-hb-primary btn-add-note" @onclick="AddNote"
                            disabled="@(string.IsNullOrWhiteSpace(_newNote))">
                        <i class="bi bi-send"></i>
                    </button>
                </div>
            </div>

            @if (_transaction.Notes.Any())
            {
                <div class="notes-list">
                    @foreach (var note in _transaction.Notes.OrderByDescending(n => n.CreatedAt))
                    {
                        <div class="note-item">
                            <div class="note-header">
                                <i class="bi bi-person-circle"></i>
                                <span class="note-date">@note.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
                            </div>
                            <p class="note-content">@note.Content</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="empty-text">لا توجد ملاحظات</p>
            }
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private Transaction? _transaction;
    private bool _loading = true;
    private bool _processing;
    private string? _successMessage, _errorMessage;
    private string? _actionNotes;
    private string? _newNote;
    private IReadOnlyCollection<TransactionStatus> _allowedTransitions = [];
    private readonly TransactionStateMachine _stateMachine = new();
    private Guid? _previewDocId;
    private bool _pdfFullscreen;
    private TransactionDocument? _deleteDoc;

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        _transaction = await db.Transactions
            .AsNoTracking()
            .Include(t => t.SenderBranch)
            .Include(t => t.ReceiverBranch)
            .Include(t => t.SenderDepartment)
            .Include(t => t.ReceiverDepartment)
            .Include(t => t.Documents)
            .Include(t => t.History)
            .Include(t => t.Notes)
            .FirstOrDefaultAsync(t => t.Id == Id);

        if (_transaction != null)
            _allowedTransitions = _stateMachine.GetContextualTransitions(_transaction);

        _loading = false;
    }

    private async Task HandleTransition(TransactionStatus targetStatus)
    {
        if (_transaction is null) return;
        _processing = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            // Use a fresh DbContext for each operation (Blazor Server best practice)
            using var db = await DbFactory.CreateDbContextAsync();

            var fresh = await db.Transactions
                .Include(t => t.SenderBranch)
                .Include(t => t.ReceiverBranch)
                .Include(t => t.SenderDepartment)
                .Include(t => t.ReceiverDepartment)
                .Include(t => t.Documents)
                .Include(t => t.History)
                .Include(t => t.Notes)
                .FirstOrDefaultAsync(t => t.Id == _transaction.Id);

            if (fresh is null)
            {
                _errorMessage = "المعاملة غير موجودة";
                return;
            }

            var result = _stateMachine.TransitionTo(
                fresh, targetStatus, CurrentUser.UserId, _actionNotes);

            if (!result.IsSuccess)
            {
                _errorMessage = result.Error;
                return;
            }

            await db.SaveChangesAsync();

            // Update the display model (no-tracking copy)
            _transaction = fresh;
            _successMessage = $"تم تنفيذ الإجراء: {GetActionLabel(targetStatus)}";
            _actionNotes = null;
            _allowedTransitions = _stateMachine.GetContextualTransitions(_transaction);

            // Send notification to involved users
            try
            {
                var title = $"تحديث المعاملة {_transaction.ReferenceNumber}";
                var message = $"تم تغيير حالة المعاملة إلى: {GetStatusLabel(targetStatus)}";

                if (_transaction.ReceiverUserId != CurrentUser.UserId)
                {
                    await NotificationService.NotifyUserAsync(
                        _transaction.ReceiverUserId, title, message, _transaction.Id,
                        Domain.Enums.NotificationType.TransactionStatusChanged);
                }

                if (_transaction.SenderUserId != CurrentUser.UserId)
                {
                    await NotificationService.NotifyUserAsync(
                        _transaction.SenderUserId, title, message, _transaction.Id,
                        Domain.Enums.NotificationType.TransactionStatusChanged);
                }
            }
            catch
            {
                // Notification failure should not block the transition
            }

            // Send email for Urgent/Critical transactions
            if (_transaction.Priority is TransactionPriority.Urgent or TransactionPriority.Critical)
            {
                try
                {
                    var emailSubject = $"[{GetPriorityLabel(_transaction.Priority)}] تحديث المعاملة {_transaction.ReferenceNumber}";
                    var emailBody = $"""
                        <div dir="rtl" style="font-family:Tajawal,sans-serif;">
                            <h2 style="color:#003d7a;">تحديث معاملة {GetPriorityLabel(_transaction.Priority)}</h2>
                            <p><strong>المرجع:</strong> {_transaction.ReferenceNumber}</p>
                            <p><strong>الموضوع:</strong> {_transaction.Subject}</p>
                            <p><strong>الحالة الجديدة:</strong> {GetStatusLabel(targetStatus)}</p>
                            <hr/>
                            <p style="color:#666;">نظام عمليات بنك حضرموت</p>
                        </div>
                        """;
                    if (_transaction.ReceiverUserId != CurrentUser.UserId)
                        await EmailService.SendToUserAsync(_transaction.ReceiverUserId, emailSubject, emailBody);
                    if (_transaction.SenderUserId != CurrentUser.UserId)
                        await EmailService.SendToUserAsync(_transaction.SenderUserId, emailSubject, emailBody);
                }
                catch
                {
                    // Email failure should not block the transition
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"حدث خطأ: {ex.Message}";
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task AddNote()
    {
        if (_transaction is null || string.IsNullOrWhiteSpace(_newNote)) return;
        try
        {
            var note = new TransactionNote
            {
                Id = Guid.NewGuid(),
                TransactionId = _transaction.Id,
                Content = _newNote,
                UserId = CurrentUser.UserId,
                CreatedAt = DateTime.UtcNow
            };
            _transaction.Notes.Add(note);
            using var db = await DbFactory.CreateDbContextAsync();
            db.TransactionNotes.Add(note);
            await db.SaveChangesAsync();
            _newNote = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"خطأ في إضافة الملاحظة: {ex.Message}";
        }
    }

    private async Task HandleNoteKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newNote))
            await AddNote();
    }

    private static string GetActionLabel(TransactionStatus to) => to switch
    {
        TransactionStatus.PendingReview => "إرسال للمراجعة",
        TransactionStatus.PendingSecondApproval => "اعتماد أول (توقيع مزدوج)",
        TransactionStatus.Approved => "اعتماد",
        TransactionStatus.InTransit => "إرسال",
        TransactionStatus.Received => "تأكيد الاستلام",
        TransactionStatus.Confirmed => "تأكيد نهائي",
        TransactionStatus.Returned => "إرجاع",
        TransactionStatus.Disputed => "فتح نزاع",
        TransactionStatus.Cancelled => "إلغاء",
        TransactionStatus.Archived => "أرشفة",
        TransactionStatus.Draft => "إعادة كمسودة",
        _ => to.ToString()
    };

    private static string GetActionBtnClass(TransactionStatus to) => to switch
    {
        TransactionStatus.PendingReview or TransactionStatus.PendingSecondApproval or TransactionStatus.Approved or TransactionStatus.InTransit
            => "workflow-btn-primary",
        TransactionStatus.Received or TransactionStatus.Confirmed or TransactionStatus.Archived
            => "workflow-btn-success",
        TransactionStatus.Returned or TransactionStatus.Cancelled
            => "workflow-btn-danger",
        TransactionStatus.Disputed => "workflow-btn-warning",
        TransactionStatus.Draft => "workflow-btn-secondary",
        _ => ""
    };

    private static string GetStatusLabel(TransactionStatus s) => s switch
    {
        TransactionStatus.Draft => "مسودة",
        TransactionStatus.PendingReview => "قيد المراجعة",
        TransactionStatus.Approved => "معتمدة",
        TransactionStatus.PendingSecondApproval => "بانتظار الاعتماد الثاني",
