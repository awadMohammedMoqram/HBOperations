    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private async Task ReloadDocuments()
    {
        if (_transaction is null) return;
        using var db = await DbFactory.CreateDbContextAsync();
        _transaction.Documents = await db.TransactionDocuments
            .Where(d => d.TransactionId == _transaction.Id)
            .ToListAsync();
        StateHasChanged();
    }

    private void PreviewDocument(Guid docId)
    {
        _previewDocId = docId;
        _pdfFullscreen = false;
    }

    private void ClosePreview()
    {
        _previewDocId = null;
        _pdfFullscreen = false;
    }

    private void TogglePdfFullscreen()
    {
        _pdfFullscreen = !_pdfFullscreen;
    }

    private void HandlePreviewKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Escape") ClosePreview();
        if (e.Key == "f" || e.Key == "F") TogglePdfFullscreen();
    }

    private void OpenDeleteDocModal(TransactionDocument doc)
    {
        _deleteDoc = doc;
    }

    private async Task DeleteDocument()
    {
        if (_deleteDoc is null || _transaction is null) return;
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.TransactionDocuments.FindAsync(_deleteDoc.Id);
            if (entity is not null)
            {
                db.TransactionDocuments.Remove(entity);
                await db.SaveChangesAsync();
                _transaction.Documents.Remove(_deleteDoc);
                _successMessage = $"تم حذف المستند: {_deleteDoc.OriginalFileName}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"خطأ في حذف المستند: {ex.Message}";
        }
        finally
        {
            _deleteDoc = null;
        }
    }
