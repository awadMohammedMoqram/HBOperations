@page "/login-2fa"
@using Microsoft.AspNetCore.Identity
@using HBOperations.Infrastructure.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation
@layout HBOperations.Web.Components.Layout.EmptyLayout

<div class="login-container">
    <div class="login-box">
        <div class="login-card hb-card">
            <div class="login-header">
                <h2 style="color:var(--hb-primary);"><i class="bi bi-shield-lock"></i> التحقق بخطوتين</h2>
                <p style="color:var(--hb-text-muted);">أدخل رمز التحقق من تطبيق المصادقة</p>
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert-hb alert-danger">
                    <i class="bi bi-x-circle"></i> @_errorMessage
                </div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleVerify" FormName="twoFactorForm">
                <div class="hb-form-group" style="margin-bottom:1.5rem;">
                    <label class="hb-form-label">رمز التحقق (6 أرقام)</label>
                    <InputText class="hb-form-control" style="text-align:center; font-size:1.5rem; letter-spacing:0.5rem;"
                               @bind-Value="_model.Code" maxlength="6" placeholder="000000" />
                </div>
                <button type="submit" class="btn-hb-primary" style="width:100%;" disabled="@_processing">
                    @if (_processing) { <span class="spinner-border spinner-border-sm"></span> }
                    تحقق
                </button>
            </EditForm>

            <div style="text-align:center; margin-top:1rem;">
                <a href="/login" style="color:var(--hb-primary);">العودة لتسجيل الدخول</a>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private bool rememberMe { get; set; }

    [SupplyParameterFromForm]
    private TwoFactorModel _model { get; set; } = new();

    private string? _errorMessage;
    private bool _processing;

    private async Task HandleVerify()
    {
        _processing = true;
        _errorMessage = null;

        try
        {
            var code = _model.Code?.Replace(" ", "").Replace("-", "") ?? "";
            var result = await SignInManager.TwoFactorAuthenticatorSignInAsync(code, rememberMe, rememberClient: false);

            if (result.Succeeded)
            {
                Navigation.NavigateTo("/", forceLoad: true);
                return;
            }

            if (result.IsLockedOut)
                _errorMessage = "تم قفل الحساب مؤقتاً.";
            else
                _errorMessage = "رمز التحقق غير صحيح. حاول مرة أخرى.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"خطأ: {ex.Message}";
        }
        finally
        {
            _processing = false;
        }
    }

    private sealed class TwoFactorModel
    {
        public string Code { get; set; } = "";
    }
}
