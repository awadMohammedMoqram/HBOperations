@page "/change-password"
@using Microsoft.AspNetCore.Identity
@using HBOperations.Infrastructure.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="change-password-container">
    <div class="hb-card" style="max-width:500px; margin:60px auto; padding:2rem;">
        <h2 style="text-align:center; color:var(--hb-primary); margin-bottom:1.5rem;">
            <i class="bi bi-key"></i> تغيير كلمة المرور
        </h2>

        @if (_expired)
        {
            <div class="alert-hb alert-warning" style="margin-bottom:1rem;">
                <i class="bi bi-exclamation-triangle"></i>
                انتهت صلاحية كلمة المرور. يرجى تعيين كلمة مرور جديدة للمتابعة.
            </div>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert-hb alert-danger" style="margin-bottom:1rem;">
                <i class="bi bi-x-circle"></i> @_errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert-hb alert-success" style="margin-bottom:1rem;">
                <i class="bi bi-check-circle"></i> @_successMessage
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleChangePassword" FormName="changePasswordForm">
            <div class="hb-form-group" style="margin-bottom:1rem;">
                <label class="hb-form-label">كلمة المرور الحالية</label>
                <InputText type="password" class="hb-form-control" @bind-Value="_model.CurrentPassword" />
            </div>
            <div class="hb-form-group" style="margin-bottom:1rem;">
                <label class="hb-form-label">كلمة المرور الجديدة</label>
                <InputText type="password" class="hb-form-control" @bind-Value="_model.NewPassword" />
                <small style="color:var(--hb-text-muted);">12 حرف على الأقل: أحرف كبيرة + صغيرة + أرقام + رموز</small>
            </div>
            <div class="hb-form-group" style="margin-bottom:1.5rem;">
                <label class="hb-form-label">تأكيد كلمة المرور الجديدة</label>
                <InputText type="password" class="hb-form-control" @bind-Value="_model.ConfirmPassword" />
            </div>
            <button type="submit" class="btn-hb-primary" style="width:100%;" disabled="@_processing">
                @if (_processing)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                تغيير كلمة المرور
            </button>
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private bool expired { get; set; }

    [SupplyParameterFromForm]
    private ChangePasswordModel _model { get; set; } = new();

    private bool _expired;
    private bool _processing;
    private string? _errorMessage;
    private string? _successMessage;

    protected override void OnInitialized()
    {
        _expired = expired;
    }

    private async Task HandleChangePassword()
    {
        _processing = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            if (string.IsNullOrWhiteSpace(_model.CurrentPassword) ||
                string.IsNullOrWhiteSpace(_model.NewPassword) ||
                string.IsNullOrWhiteSpace(_model.ConfirmPassword))
            {
                _errorMessage = "يرجى تعبئة جميع الحقول";
                return;
            }

            if (_model.NewPassword != _model.ConfirmPassword)
            {
                _errorMessage = "كلمة المرور الجديدة وتأكيدها غير متطابقين";
                return;
            }

            if (_model.NewPassword.Length < 12)
            {
                _errorMessage = "كلمة المرور الجديدة يجب أن تكون 12 حرفاً على الأقل";
                return;
            }

            var user = await UserManager.GetUserAsync(SignInManager.Context.User);
            if (user is null)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            var result = await UserManager.ChangePasswordAsync(user, _model.CurrentPassword, _model.NewPassword);
            if (!result.Succeeded)
            {
                _errorMessage = string.Join(" | ", result.Errors.Select(e => e.Description));
                return;
            }

            user.PasswordChangedAt = DateTime.UtcNow;
            user.ForcePasswordChange = false;
            await UserManager.UpdateAsync(user);

            _successMessage = "تم تغيير كلمة المرور بنجاح. سيتم تحويلك...";
            await Task.Delay(1500);
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            _errorMessage = $"حدث خطأ: {ex.Message}";
        }
        finally
        {
            _processing = false;
        }
    }

    private sealed class ChangePasswordModel
    {
        public string CurrentPassword { get; set; } = "";
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
