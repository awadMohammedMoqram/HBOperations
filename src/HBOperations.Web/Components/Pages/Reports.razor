@page "/reports"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin,CEO,AssistantCEO,DepartmentManager,BranchManager,OfficeManager,Auditor,ComplianceOfficer,ITAdmin")]
@using HBOperations.Application.Common.Interfaces
@using HBOperations.Domain.Enums
@using HBOperations.Domain.Entities
@using Microsoft.EntityFrameworkCore
@inject IAppDbContext DbContext
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>التقارير - بنك حضرموت</PageTitle>

<div class="page-container hb-fade-in">
    <div class="page-title-section">
        <div>
            <h1 class="section-title"><i class="bi bi-graph-up"></i> التقارير والإحصائيات</h1>
            <p class="section-subtitle">تقارير تفصيلية عن المعاملات والفروع والأداء</p>
        </div>
    </div>

    <!-- Report Tabs -->
    <div class="report-tabs">
        <button class="report-tab @(_activeTab == "branch" ? "active" : "")" @onclick='() => _activeTab = "branch"'>
            <i class="bi bi-building"></i> تقرير الفروع
        </button>
        <button class="report-tab @(_activeTab == "performance" ? "active" : "")" @onclick='() => _activeTab = "performance"'>
            <i class="bi bi-speedometer2"></i> تقرير الأداء
        </button>
        <button class="report-tab @(_activeTab == "type" ? "active" : "")" @onclick='() => _activeTab = "type"'>
            <i class="bi bi-pie-chart"></i> تقرير الأنواع
        </button>
    </div>

    @if (_loading)
    {
        <div class="hb-loading"><div class="hb-spinner"></div><span>جاري تحميل التقارير...</span></div>
    }
    else
    {
        <!-- ═══ Branch Report ═══ -->
        @if (_activeTab == "branch")
        {
            <div class="hb-card report-card">
                <div class="report-header">
                    <h2><i class="bi bi-building"></i> تقرير المعاملات حسب الفرع</h2>
                    <button class="btn-hb-outline btn-sm" @onclick="ExportBranchReport">
                        <i class="bi bi-download"></i> تصدير Excel
                    </button>
                </div>
                <div class="report-table-wrap">
                    <table class="report-table">
                        <thead>
                            <tr>
                                <th>الفرع</th>
                                <th>الصادرة</th>
                                <th>الواردة</th>
                                <th>الإجمالي</th>
                                <th>بانتظار الاستلام</th>
                                <th>مكتملة</th>
                                <th>ملغاة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _branchReport)
                            {
                                <tr>
                                    <td class="branch-name-cell">
                                        <strong>@row.BranchName</strong>
                                    </td>
                                    <td><span class="num-cell">@row.Outgoing</span></td>
                                    <td><span class="num-cell">@row.Incoming</span></td>
                                    <td><span class="num-cell total-cell">@row.Total</span></td>
                                    <td><span class="num-cell pending-cell">@row.Pending</span></td>
                                    <td><span class="num-cell success-cell">@row.Completed</span></td>
                                    <td><span class="num-cell danger-cell">@row.Cancelled</span></td>
                                </tr>
                            }
                        </tbody>
                        @if (_branchReport.Any())
                        {
                            <tfoot>
                                <tr class="total-row">
                                    <td><strong>الإجمالي</strong></td>
                                    <td><strong>@_branchReport.Sum(r => r.Outgoing)</strong></td>
                                    <td><strong>@_branchReport.Sum(r => r.Incoming)</strong></td>
                                    <td><strong>@_branchReport.Sum(r => r.Total)</strong></td>
                                    <td><strong>@_branchReport.Sum(r => r.Pending)</strong></td>
                                    <td><strong>@_branchReport.Sum(r => r.Completed)</strong></td>
                                    <td><strong>@_branchReport.Sum(r => r.Cancelled)</strong></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
        }

        <!-- ═══ Performance Report ═══ -->
        @if (_activeTab == "performance")
        {
            <div class="hb-card report-card">
                <div class="report-header">
                    <h2><i class="bi bi-speedometer2"></i> تقرير الأداء — متوسط زمن المعالجة</h2>
                </div>
                <div class="report-table-wrap">
                    <table class="report-table">
                        <thead>
                            <tr>
                                <th>الفرع</th>
                                <th>عدد المعاملات المكتملة</th>
                                <th>متوسط زمن المعالجة</th>
                                <th>أسرع معاملة</th>
                                <th>أبطأ معاملة</th>
                                <th>الأداء</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _performanceReport)
                            {
                                <tr>
                                    <td><strong>@row.BranchName</strong></td>
                                    <td class="num-cell">@row.CompletedCount</td>
                                    <td class="num-cell">@FormatDuration(row.AvgProcessingHours)</td>
                                    <td class="num-cell">@FormatDuration(row.MinProcessingHours)</td>
                                    <td class="num-cell">@FormatDuration(row.MaxProcessingHours)</td>
                                    <td>
                                        <div class="perf-bar-track">
                                            <div class="perf-bar-fill @GetPerfClass(row.AvgProcessingHours)" 
                                                 style="width: @GetPerfPercent(row.AvgProcessingHours)%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!_performanceReport.Any())
                {
                    <div class="empty-report">
                        <i class="bi bi-speedometer"></i>
                        <p>لا توجد معاملات مكتملة لحساب الأداء</p>
                    </div>
                }
            </div>
        }

        <!-- ═══ Type Report ═══ -->
        @if (_activeTab == "type")
        {
            <div class="hb-card report-card">
                <div class="report-header">
                    <h2><i class="bi bi-pie-chart"></i> تقرير المعاملات حسب النوع</h2>
                </div>
                <div class="type-report-grid">
                    @foreach (var item in _typeReport)
                    {
                        var percent = _totalCount > 0 ? (double)item.Count / _totalCount * 100 : 0;
                        <div class="type-report-card">
                            <div class="type-report-icon">
                                <i class="bi @GetTypeIcon(item.Type)"></i>
                            </div>
                            <div class="type-report-info">
                                <span class="type-report-name">@GetTypeLabel(item.Type)</span>
                                <span class="type-report-count">@item.Count معاملة</span>
                            </div>
                            <div class="type-report-percent">@percent.ToString("F1")%</div>
                            <div class="type-report-bar">
                                <div class="type-report-bar-fill" style="width: @percent.ToString("F0")%"></div>
                            </div>
                        </div>
                    }
                </div>
                @if (!_typeReport.Any())
                {
                    <div class="empty-report">
                        <i class="bi bi-pie-chart"></i>
                        <p>لا توجد بيانات</p>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private string _activeTab = "branch";
    private bool _loading = true;
    private int _totalCount;

    // Branch Report
    private List<BranchReportRow> _branchReport = [];

    // Performance Report
    private List<PerformanceRow> _performanceReport = [];

    // Type Report
    private List<TypeReportRow> _typeReport = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadReports();
        _loading = false;
    }

    private async Task LoadReports()
    {
        // Only SuperAdmin/CEO/ITAdmin see all; everyone else sees only their personal transactions
        var globalRoles = new[] { "SuperAdmin", "CEO", "ITAdmin" };
        var hasGlobalAccess = globalRoles.Any(r => CurrentUser.IsInRole(r));

        IQueryable<Transaction> transactions = DbContext.Transactions.AsNoTracking();

        if (!hasGlobalAccess)
        {
            var userId = CurrentUser.UserId;
            var branchId = CurrentUser.BranchId;
            var deptId = CurrentUser.DepartmentId;
            transactions = transactions.Where(t =>
                t.CreatedByUserId == userId ||
                t.SenderUserId == userId ||
                (branchId.HasValue && (t.SenderBranchId == branchId || t.ReceiverBranchId == branchId)) ||
                t.ReceiverUserId == userId || (deptId.HasValue && t.SenderDepartmentId == deptId));
        }

        _totalCount = await transactions.CountAsync();

        // ── Branch Report ──
        var branches = await DbContext.Branches.AsNoTracking()
            .Where(b => b.IsActive)
            .OrderBy(b => b.NameAr)
            .ToListAsync();

        var txList = await transactions
            .Select(t => new { t.SenderBranchId, t.ReceiverBranchId, t.Status })
            .ToListAsync();

        _branchReport = branches.Select(b => new BranchReportRow
        {
            BranchName = b.NameAr,
            Outgoing = txList.Count(t => t.SenderBranchId == b.Id),
            Incoming = txList.Count(t => t.ReceiverBranchId == b.Id),
            Pending = txList.Count(t => (t.SenderBranchId == b.Id || t.ReceiverBranchId == b.Id) && t.Status == TransactionStatus.Sent),
            Completed = txList.Count(t => (t.SenderBranchId == b.Id || t.ReceiverBranchId == b.Id) && (t.Status == TransactionStatus.Received || t.Status == TransactionStatus.Archived)),
            Cancelled = txList.Count(t => (t.SenderBranchId == b.Id || t.ReceiverBranchId == b.Id) && t.Status == TransactionStatus.Cancelled)
        }).Where(r => r.Total > 0).ToList();

        // ── Performance Report ──
        var completedTx = await transactions
            .Where(t => t.CompletedAt.HasValue)
            .Select(t => new { t.ReceiverBranchId, t.CreatedAt, t.CompletedAt })
            .ToListAsync();

        _performanceReport = completedTx
            .Where(t => t.ReceiverBranchId.HasValue)
            .GroupBy(t => t.ReceiverBranchId!.Value)
            .Select(g =>
            {
                var hours = g.Select(t => (t.CompletedAt!.Value - t.CreatedAt).TotalHours).ToList();
                var branch = branches.FirstOrDefault(b => b.Id == g.Key);
                return new PerformanceRow
                {
                    BranchName = branch?.NameAr ?? "غير محدد",
                    CompletedCount = g.Count(),
                    AvgProcessingHours = hours.Average(),
                    MinProcessingHours = hours.Min(),
                    MaxProcessingHours = hours.Max()
                };
            })
            .OrderBy(r => r.AvgProcessingHours)
            .ToList();

        // ── Type Report ──
        _typeReport = await transactions
            .GroupBy(t => t.Type)
            .Select(g => new TypeReportRow { Type = g.Key, Count = g.Count() })
            .OrderByDescending(x => x.Count)
            .ToListAsync();
    }

    private async Task ExportBranchReport()
    {
        var url = Nav.ToAbsoluteUri("/api/reports/branches/export").ToString();
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    // ── Helper Methods ──

    private static string FormatDuration(double hours)
    {
        if (hours < 1) return $"{(int)(hours * 60)} دقيقة";
        if (hours < 24) return $"{hours:F1} ساعة";
        return $"{hours / 24:F1} يوم";
    }

    private static string GetPerfClass(double avgHours)
    {
        if (avgHours <= 4) return "perf-excellent";
        if (avgHours <= 24) return "perf-good";
        if (avgHours <= 72) return "perf-average";
        return "perf-slow";
    }

    private static int GetPerfPercent(double avgHours)
    {
        // Inverse scale: faster = wider bar (max 168h = 1 week)
        var percent = 100 - (int)(avgHours / 168 * 100);
        return Math.Clamp(percent, 5, 100);
    }

    private static string GetTypeIcon(TransactionType t) => t switch
    {
        TransactionType.BranchToBranch => "bi-arrow-left-right",
        TransactionType.CashTransfer => "bi-cash-stack",
        TransactionType.DocumentDelivery => "bi-file-earmark-arrow-up",
        TransactionType.InternalDepartment => "bi-diagram-3",
        _ => "bi-file-earmark-text"
    };

    private static string GetTypeLabel(TransactionType t) => t switch
    {
        TransactionType.DocumentDelivery => "تسليم مستندات",
        TransactionType.CashTransfer => "تحويل نقدي",
        TransactionType.InternalDepartment => "داخلي بين الإدارات",
        TransactionType.BranchToBranch => "بين الفروع",
        TransactionType.Other => "أخرى",
        _ => t.ToString()
    };

    // ── Report Models ──

    private class BranchReportRow
    {
        public string BranchName { get; set; } = "";
        public int Outgoing { get; set; }
        public int Incoming { get; set; }
        public int Total => Outgoing + Incoming;
        public int Pending { get; set; }
        public int Completed { get; set; }
        public int Cancelled { get; set; }
    }

    private class PerformanceRow
    {
        public string BranchName { get; set; } = "";
        public int CompletedCount { get; set; }
        public double AvgProcessingHours { get; set; }
        public double MinProcessingHours { get; set; }
        public double MaxProcessingHours { get; set; }
    }

    private class TypeReportRow
    {
        public TransactionType Type { get; set; }
        public int Count { get; set; }
    }
}
