@page "/users"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin,ITAdmin")]
@using HBOperations.Application.Common.Interfaces
@using HBOperations.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<ApplicationRole> RoleManager
@inject IAppDbContext DbContext

<PageTitle>المستخدمين - بنك حضرموت</PageTitle>

<div class="page-container hb-fade-in">
    <div class="page-title-section">
        <div class="title-with-action">
            <div>
                <h1 class="section-title"><i class="bi bi-people"></i> إدارة المستخدمين</h1>
                <p class="section-subtitle">إدارة حسابات المستخدمين والصلاحيات</p>
            </div>
            <button class="btn-hb-primary" @onclick="OpenAddModal">
                <i class="bi bi-person-plus"></i> إضافة مستخدم
            </button>
        </div>
    </div>

    <!-- Search -->
    <div class="hb-card filter-card">
        <div class="search-row">
            <div class="filter-group">
                <label class="hb-form-label">بحث</label>
                <input type="text" class="hb-form-control" placeholder="الاسم أو البريد الإلكتروني..."
                       @bind="_searchTerm" @bind:event="oninput" />
            </div>
            <div class="filter-group">
                <label class="hb-form-label">الحالة</label>
                <select class="hb-form-control" @bind="_activeFilter">
                    <option value="">الكل</option>
                    <option value="true">نشط</option>
                    <option value="false">معطل</option>
                </select>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="hb-alert hb-alert-success">
            <i class="bi bi-check-circle-fill"></i> @_successMessage
        </div>
    }

    <!-- Stats -->
    <div class="user-stats">
        <div class="stat-item">
            <i class="bi bi-people-fill"></i>
            <span class="stat-number">@_users.Count</span>
            <span class="stat-label">إجمالي المستخدمين</span>
        </div>
        <div class="stat-item stat-active">
            <i class="bi bi-person-check-fill"></i>
            <span class="stat-number">@_users.Count(u => u.IsActive)</span>
            <span class="stat-label">نشط</span>
        </div>
        <div class="stat-item stat-inactive">
            <i class="bi bi-person-x-fill"></i>
            <span class="stat-number">@_users.Count(u => !u.IsActive)</span>
            <span class="stat-label">معطل</span>
        </div>
    </div>

    @if (_loading)
    {
        <div class="hb-loading">
            <div class="hb-spinner"></div>
            <span>جاري تحميل المستخدمين...</span>
        </div>
    }
    else
    {
        <div class="table-container">
            <table class="hb-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>الاسم</th>
                        <th>البريد الإلكتروني</th>
                        <th>الرقم الوظيفي</th>
                        <th>المسمى الوظيفي</th>
                        <th>الفرع</th>
                        <th>الحالة</th>
                        <th>آخر دخول</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var index = 0; }
                    @foreach (var user in GetFilteredUsers())
                    {
                        index++;
                        <tr>
                            <td>@index</td>
                            <td class="user-name-cell">
                                <div class="user-avatar">@GetInitials(user.FullNameAr)</div>
                                <span>@user.FullNameAr</span>
                            </td>
                            <td dir="ltr" style="text-align:center;">@user.Email</td>
                            <td style="text-align:center;">@(user.EmployeeNumber ?? "—")</td>
                            <td>@(user.JobTitle ?? "—")</td>
                            <td>@(_branchNames.GetValueOrDefault(user.BranchId ?? Guid.Empty, "—"))</td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="hb-badge hb-badge-success">نشط</span>
                                }
                                else
                                {
                                    <span class="hb-badge hb-badge-danger">معطل</span>
                                }
                            </td>
                            <td class="date-cell">
                                @(user.LastLoginAt?.ToString("yyyy/MM/dd HH:mm") ?? "لم يسجل دخول")
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <button class="action-btn edit" title="تعديل" @onclick="() => OpenEditModal(user)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="action-btn delete" title="حذف" @onclick="() => OpenDeleteModal(user)">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* ===== Add/Edit Modal ===== *@
@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3><i class="bi bi-@(_editingUser != null ? "pencil-square" : "person-plus")"></i> @(_editingUser != null ? "تعديل المستخدم" : "إضافة مستخدم جديد")</h3>
                <button class="modal-close" @onclick="CloseModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <EditForm Model="_model" OnValidSubmit="HandleSave" FormName="UserForm">
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="hb-alert hb-alert-danger" style="margin-bottom:1rem;">
                            <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
                        </div>
                    }
                    <div class="form-grid">
                        <div class="hb-form-group">
                            <label class="hb-form-label">الاسم الكامل *</label>
                            <InputText @bind-Value="_model.FullNameAr" class="hb-form-control" placeholder="الاسم بالعربي" />
                        </div>
                        <div class="hb-form-group">
                            <label class="hb-form-label">البريد الإلكتروني *</label>
                            <InputText @bind-Value="_model.Email" class="hb-form-control" placeholder="user@hadhramoutbank.com" />
                        </div>
                        @if (_editingUser == null)
                        {
                            <div class="hb-form-group">
                                <label class="hb-form-label">كلمة المرور *</label>
                                <InputText @bind-Value="_model.Password" type="password" class="hb-form-control" placeholder="كلمة المرور" />
                            </div>
                        }
                        <div class="hb-form-group">
                            <label class="hb-form-label">الرقم الوظيفي</label>
                            <InputText @bind-Value="_model.EmployeeNumber" class="hb-form-control" placeholder="مثال: EMP-001" />
                        </div>
                        <div class="hb-form-group">
                            <label class="hb-form-label">المسمى الوظيفي</label>
                            <InputText @bind-Value="_model.JobTitle" class="hb-form-control" placeholder="المسمى الوظيفي" />
                        </div>
                        <div class="hb-form-group">
                            <label class="hb-form-label">الفرع</label>
                            <InputSelect @bind-Value="_model.BranchId" class="hb-form-control">
                                <option value="">-- بدون --</option>
                                @foreach (var b in _allBranches)
                                {
                                    <option value="@b.Id">@b.NameAr</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="hb-form-group">
                            <label class="hb-form-label">الدور</label>
                            <InputSelect @bind-Value="_model.Role" class="hb-form-control">
                                <option value="">-- بدون --</option>
                                @foreach (var role in _allRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="hb-form-group">
                            <label class="hb-form-label">الحالة</label>
                            <InputSelect @bind-Value="_model.IsActive" class="hb-form-control">
                                <option value="true">نشط</option>
                                <option value="false">معطل</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn-hb-primary" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="hb-spinner" style="width:18px;height:18px;border-width:2px;"></span>
                            <span>جاري الحفظ...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg"></i>
                            <span>@(_editingUser != null ? "تحديث" : "حفظ")</span>
                        }
                    </button>
                    <button type="button" class="btn-hb-outline" @onclick="CloseModal">إلغاء</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@* ===== Delete Confirmation Modal ===== *@
@if (_showDeleteModal)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="modal-content modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header modal-header-danger">
                <h3><i class="bi bi-exclamation-triangle"></i> تأكيد الحذف</h3>
                <button class="modal-close" @onclick="CloseDeleteModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="hb-alert hb-alert-danger" style="margin-bottom:1rem;">
                        <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
                    </div>
                }
                <p class="delete-message">هل أنت متأكد من حذف المستخدم <strong>@_deletingUser?.FullNameAr</strong>؟</p>
                <p class="delete-warning"><i class="bi bi-info-circle"></i> هذا الإجراء لا يمكن التراجع عنه.</p>
            </div>
            <div class="modal-footer">
                <button class="btn-hb-danger" @onclick="HandleDelete" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="hb-spinner" style="width:18px;height:18px;border-width:2px;"></span>
                    }
                    <i class="bi bi-trash3"></i> حذف
                </button>
                <button class="btn-hb-outline" @onclick="CloseDeleteModal">إلغاء</button>
            </div>
        </div>
    </div>
}

@code {
    private List<ApplicationUser> _users = [];
    private Dictionary<Guid, string> _branchNames = [];
    private List<HBOperations.Domain.Entities.Branch> _allBranches = [];
    private List<string> _allRoles = [];
    private bool _loading = true;
    private string _searchTerm = "";
    private string _activeFilter = "";

    // Modal state
    private bool _showModal, _showDeleteModal, _saving;
    private string? _successMessage, _errorMessage;
    private ApplicationUser? _editingUser;
    private ApplicationUser? _deletingUser;
    private UserFormModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _users = await UserManager.Users
            .OrderBy(u => u.FullNameAr)
            .ToListAsync();

        _branchNames = await DbContext.Branches
            .ToDictionaryAsync(b => b.Id, b => b.NameAr);

        _allBranches = await DbContext.Branches
            .Where(b => b.IsActive)
            .OrderBy(b => b.NameAr)
            .ToListAsync();

        _allRoles = await RoleManager.Roles
            .OrderBy(r => r.Name)
            .Select(r => r.Name!)
            .ToListAsync();

        _loading = false;
    }

    private IEnumerable<ApplicationUser> GetFilteredUsers()
    {
        var query = _users.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchTerm))
            query = query.Where(u =>
                (u.FullNameAr?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (u.Email?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

        if (bool.TryParse(_activeFilter, out var isActive))
            query = query.Where(u => u.IsActive == isActive);

        return query;
    }

    // ===== Add =====
    private void OpenAddModal()
    {
        _editingUser = null;
        _model = new();
        _errorMessage = null;
        _showModal = true;
    }

    // ===== Edit =====
    private async void OpenEditModal(ApplicationUser user)
    {
        _editingUser = user;
        var roles = await UserManager.GetRolesAsync(user);
        _model = new UserFormModel
        {
            FullNameAr = user.FullNameAr,
            Email = user.Email ?? "",
            EmployeeNumber = user.EmployeeNumber,
            JobTitle = user.JobTitle,
            BranchId = user.BranchId?.ToString(),
            Role = roles.FirstOrDefault() ?? "",
            IsActive = user.IsActive
        };
        _errorMessage = null;
        _showModal = true;
        StateHasChanged();
    }

    private async Task HandleSave()
    {
        _saving = true;
        _errorMessage = null;
        try
        {
            if (string.IsNullOrWhiteSpace(_model.FullNameAr) || string.IsNullOrWhiteSpace(_model.Email))
            {
                _errorMessage = "يرجى إدخال الاسم والبريد الإلكتروني";
                return;
            }

            if (_editingUser != null)
            {
                // Update
                _editingUser.FullNameAr = _model.FullNameAr;
                _editingUser.Email = _model.Email;
                _editingUser.UserName = _model.Email;
                _editingUser.NormalizedEmail = _model.Email.ToUpperInvariant();
                _editingUser.NormalizedUserName = _model.Email.ToUpperInvariant();
                _editingUser.EmployeeNumber = _model.EmployeeNumber;
                _editingUser.JobTitle = _model.JobTitle;
                _editingUser.BranchId = string.IsNullOrEmpty(_model.BranchId) ? null : Guid.Parse(_model.BranchId);
                _editingUser.IsActive = _model.IsActive;

                var result = await UserManager.UpdateAsync(_editingUser);
                if (!result.Succeeded)
                {
                    _errorMessage = string.Join("، ", result.Errors.Select(e => e.Description));
                    return;
                }

                // Update role
                var currentRoles = await UserManager.GetRolesAsync(_editingUser);
                if (currentRoles.Any())
                    await UserManager.RemoveFromRolesAsync(_editingUser, currentRoles);
                if (!string.IsNullOrEmpty(_model.Role))
                    await UserManager.AddToRoleAsync(_editingUser, _model.Role);

                _successMessage = $"تم تحديث المستخدم «{_model.FullNameAr}» بنجاح";
            }
            else
            {
                // Add
                if (string.IsNullOrWhiteSpace(_model.Password))
                {
                    _errorMessage = "يرجى إدخال كلمة المرور";
                    return;
                }

                var user = new ApplicationUser
                {
                    Id = Guid.NewGuid(),
                    FullNameAr = _model.FullNameAr,
                    Email = _model.Email,
                    UserName = _model.Email,
                    EmployeeNumber = _model.EmployeeNumber,
                    JobTitle = _model.JobTitle,
                    BranchId = string.IsNullOrEmpty(_model.BranchId) ? null : Guid.Parse(_model.BranchId),
                    IsActive = _model.IsActive,
                    CreatedAt = DateTime.UtcNow,
                    EmailConfirmed = true
                };

                var result = await UserManager.CreateAsync(user, _model.Password);
                if (!result.Succeeded)
                {
                    _errorMessage = string.Join("، ", result.Errors.Select(e => e.Description));
                    return;
                }

                if (!string.IsNullOrEmpty(_model.Role))
                    await UserManager.AddToRoleAsync(user, _model.Role);

                _successMessage = $"تم إضافة المستخدم «{_model.FullNameAr}» بنجاح";
            }

            _showModal = false;
            _loading = true;
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = $"حدث خطأ: {ex.Message}";
        }
        finally { _saving = false; }
    }

    private void CloseModal() { _showModal = false; _errorMessage = null; }

    // ===== Delete =====
    private void OpenDeleteModal(ApplicationUser user)
    {
        _deletingUser = user;
        _errorMessage = null;
        _showDeleteModal = true;
    }

    private async Task HandleDelete()
    {
        _saving = true;
        _errorMessage = null;
        try
        {
            var result = await UserManager.DeleteAsync(_deletingUser!);
            if (!result.Succeeded)
            {
                _errorMessage = string.Join("، ", result.Errors.Select(e => e.Description));
                return;
            }
            _successMessage = $"تم حذف المستخدم «{_deletingUser!.FullNameAr}» بنجاح";
            _showDeleteModal = false;
            _loading = true;
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.InnerException?.Message?.Contains("REFERENCE") == true
                ? "لا يمكن حذف هذا المستخدم لأنه مرتبط بمعاملات أو بيانات أخرى"
                : $"حدث خطأ: {ex.Message}";
        }
        finally { _saving = false; }
    }

    private void CloseDeleteModal() { _showDeleteModal = false; _errorMessage = null; }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "؟";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? $"{parts[0][0]}{parts[1][0]}" : $"{parts[0][0]}";
    }

    private class UserFormModel
    {
        public string FullNameAr { get; set; } = "";
        public string Email { get; set; } = "";
        public string? Password { get; set; }
        public string? EmployeeNumber { get; set; }
        public string? JobTitle { get; set; }
        public string? BranchId { get; set; }
        public string? Role { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
