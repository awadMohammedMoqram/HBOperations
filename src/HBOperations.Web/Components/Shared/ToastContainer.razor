@using HBOperations.Web.Services
@implements IDisposable
@inject ToastService ToastService

<div class="toast-container @(_toasts.Count > 0 ? "has-toasts" : "")" aria-live="polite" aria-atomic="true">
    @foreach (var t in _toasts)
    {
        <div class="toast-card toast-@GetTypeClass(t.Type) @(_dismissing.Contains(t.Id) ? "toast-out" : "toast-in")"
             role="alert">
            <div class="toast-icon"><i class="bi @GetTypeIcon(t.Type)"></i></div>
            <div class="toast-body">
                <strong class="toast-title">@t.Title</strong>
                @if (!string.IsNullOrEmpty(t.Message))
                {
                    <span class="toast-message">@t.Message</span>
                }
            </div>
            <button type="button" class="toast-close" @onclick="() => DismissAsync(t.Id)" aria-label="إغلاق">
                <i class="bi bi-x-lg"></i>
            </button>
            <div class="toast-progress" style="--toast-duration:@(t.DurationMs)ms;"></div>
        </div>
    }
</div>

@code {
    private readonly List<ToastMessage> _toasts = new();
    private readonly HashSet<Guid> _dismissing = new();

    protected override void OnInitialized()
    {
        ToastService.OnShow += ShowAsync;
    }

    private async Task ShowAsync(ToastMessage toast)
    {
        await InvokeAsync(() =>
        {
            _toasts.Add(toast);
            StateHasChanged();
        });

        // Auto-dismiss
        _ = Task.Run(async () =>
        {
            await Task.Delay(toast.DurationMs);
            await DismissAsync(toast.Id);
        });
    }

    private async Task DismissAsync(Guid id)
    {
        await InvokeAsync(() =>
        {
            if (_toasts.All(t => t.Id != id)) return;
            _dismissing.Add(id);
            StateHasChanged();
        });

        await Task.Delay(280);

        await InvokeAsync(() =>
        {
            _toasts.RemoveAll(t => t.Id == id);
            _dismissing.Remove(id);
            StateHasChanged();
        });
    }

    private static string GetTypeClass(ToastType t) => t switch
    {
        ToastType.Success => "success",
        ToastType.Error   => "error",
        ToastType.Warning => "warning",
        _                 => "info"
    };

    private static string GetTypeIcon(ToastType t) => t switch
    {
        ToastType.Success => "bi-check-circle-fill",
        ToastType.Error   => "bi-exclamation-octagon-fill",
        ToastType.Warning => "bi-exclamation-triangle-fill",
        _                 => "bi-info-circle-fill"
    };

    public void Dispose()
    {
        ToastService.OnShow -= ShowAsync;
    }
}
