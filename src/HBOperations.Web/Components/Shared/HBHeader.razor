@* بنك حضرموت - Header Component *@
@using Microsoft.AspNetCore.Components.Authorization
@using HBOperations.Application.Common.Interfaces
@using HBOperations.Web.Services
@using Microsoft.EntityFrameworkCore
@implements IAsyncDisposable

<header class="hb-header" dir="rtl">
    <div class="header-content">
        <div class="logo-section">
            <a href="/" class="logo" @onclick="CloseMobileMenu">
                <img src="Images/aboutLogo-fDwVp-So.svg" alt="بنك حضرموت">
            </a>
            <div class="bank-name">
                <h1>بنك حضرموت</h1>
                <span class="bank-name-en">Hadhramout Bank</span>
            </div>
            <button class="menu-toggle @(isMobileMenuOpen ? "active" : "")" @onclick="ToggleMobileMenu" aria-label="قائمة التنقل">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
        <nav class="nav-links @(isMobileMenuOpen ? "active" : "")">
            <a href="/" class="nav-link @GetActiveClass("/", true)" @onclick="CloseMobileMenu">
                <i class="bi bi-speedometer2"></i> لوحة التحكم
            </a>
            <a href="/transactions" class="nav-link @GetActiveClass("/transactions")" @onclick="CloseMobileMenu">
                <i class="bi bi-file-earmark-text"></i> المعاملات
            </a>
            <a href="/branches" class="nav-link @GetActiveClass("/branches")" @onclick="CloseMobileMenu">
                <i class="bi bi-building"></i> الفروع
            </a>
            <a href="/departments" class="nav-link @GetActiveClass("/departments")" @onclick="CloseMobileMenu">
                <i class="bi bi-diagram-3"></i> الأقسام
            </a>
            <a href="/reports" class="nav-link @GetActiveClass("/reports")" @onclick="CloseMobileMenu">
                <i class="bi bi-graph-up"></i> التقارير
            </a>
            <a href="/archive" class="nav-link @GetActiveClass("/archive")" @onclick="CloseMobileMenu">
                <i class="bi bi-archive"></i> الأرشيف
            </a>

            <AuthorizeView Roles="SuperAdmin,ITAdmin">
                <a href="/users" class="nav-link @GetActiveClass("/users")" @onclick="CloseMobileMenu">
                    <i class="bi bi-people-fill"></i> المستخدمين
                </a>
                <a href="/audit-log" class="nav-link @GetActiveClass("/audit-log")" @onclick="CloseMobileMenu">
                    <i class="bi bi-clipboard-data"></i> سجل المراجعة
                </a>
                <a href="/settings" class="nav-link @GetActiveClass("/settings")" @onclick="CloseMobileMenu">
                    <i class="bi bi-gear-fill"></i> الإعدادات
                </a>
            </AuthorizeView>

            <AuthorizeView>
                <Authorized>
                    <div class="user-section">
                        <a href="/notifications" class="notif-btn @GetActiveClass("/notifications")" @onclick="CloseMobileMenu" title="الإشعارات">
                            <i class="bi bi-bell"></i>
                            @if (_unreadCount > 0)
                            {
                                <span class="notif-badge">@(_unreadCount > 99 ? "99+" : _unreadCount.ToString())</span>
                            }
                        </a>
                        <span class="user-name">@(context.User.FindFirst("FullNameAr")?.Value ?? context.User.Identity?.Name ?? "مستخدم")</span>
                        <form method="post" action="/logout">
                            <button type="submit" class="logout-btn">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>تسجيل خروج</span>
                            </button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </nav>
    </div>
</header>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private IAppDbContext DbContext { get; set; } = default!;
    [Inject] private ICurrentUserService CurrentUser { get; set; } = default!;
    [Inject] private NotificationEventService NotificationEvents { get; set; } = default!;

    private bool isMobileMenuOpen;
    private int _unreadCount;

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;

        // Load unread count from DB
        if (CurrentUser.UserId != Guid.Empty)
        {
            _unreadCount = await DbContext.Notifications
                .CountAsync(n => n.UserId == CurrentUser.UserId && !n.IsRead);
        }

        // Subscribe to in-process notification events
        NotificationEvents.OnNotification += OnNotificationReceived;
    }

    private async Task OnNotificationReceived(Guid userId)
    {
        if (userId == CurrentUser.UserId)
        {
            _unreadCount++;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();
    private void ToggleMobileMenu() => isMobileMenuOpen = !isMobileMenuOpen;
    private void CloseMobileMenu() => isMobileMenuOpen = false;

    private string GetActiveClass(string path, bool exactMatch = false)
    {
        var currentPath = new Uri(Navigation.Uri).AbsolutePath;
        return exactMatch
            ? currentPath == path ? "active" : ""
            : currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    public async ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        NotificationEvents.OnNotification -= OnNotificationReceived;
    }
}
