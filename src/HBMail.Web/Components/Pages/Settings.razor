@page "/settings"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin,ITAdmin")]
@using HBMail.Application.Common.Interfaces
@using HBMail.Domain.Entities
@using Microsoft.EntityFrameworkCore
@inject IAppDbContext DbContext
@inject ISystemSettingService SettingService

<PageTitle>إعدادات النظام - بنك حضرموت</PageTitle>

<div class="page-container hb-fade-in">
    <div class="page-title-section">
        <div>
            <h1 class="section-title"><i class="bi bi-gear-fill"></i> إعدادات النظام</h1>
            <p class="section-subtitle">تكوين وإدارة إعدادات النظام المختلفة</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="hb-alert hb-alert-success">
            <i class="bi bi-check-circle-fill"></i> @_successMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="hb-alert hb-alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
        </div>
    }

    @if (_loading)
    {
        <div class="hb-loading"><div class="hb-spinner"></div><span>جاري تحميل الإعدادات...</span></div>
    }
    else
    {
        <!-- Category Tabs -->
        <div class="settings-tabs">
            @foreach (var cat in _categories)
            {
                <button class="settings-tab @(_activeCategory == cat.Key ? "active" : "")"
                        @onclick="() => _activeCategory = cat.Key">
                    <i class="bi @GetCategoryIcon(cat.Key)"></i>
                    @cat.Value
                    <span class="tab-count">@_settings.Count(s => s.Category == cat.Key)</span>
                </button>
            }
        </div>

        <!-- Settings Cards -->
        <div class="settings-grid">
            @foreach (var setting in _settings.Where(s => s.Category == _activeCategory))
            {
                <div class="setting-card @(!setting.IsEditable ? "readonly" : "")">
                    <div class="setting-info">
                        <span class="setting-key">@setting.Key</span>
                        <span class="setting-desc">@setting.DescriptionAr</span>
                    </div>
                    <div class="setting-control">
                        @if (!setting.IsEditable)
                        {
                            <span class="setting-value-readonly">@setting.Value</span>
                            <i class="bi bi-lock-fill lock-icon" title="غير قابل للتعديل"></i>
                        }
                        else if (setting.ValueType == "bool")
                        {
                            <label class="toggle-switch">
                                <input type="checkbox" checked="@(setting.Value == "true")"
                                       @onchange="e => ToggleBool(setting, e)" />
                                <span class="toggle-slider"></span>
                            </label>
                        }
                        else if (setting.ValueType == "int")
                        {
                            <input type="number" class="setting-input setting-input-num"
                                   value="@setting.Value"
                                   @onchange="e => UpdateSettingValue(setting, e.Value?.ToString() ?? string.Empty)" />
                        }
                        else
                        {
                            <input type="text" class="setting-input"
                                   value="@setting.Value"
                                   @onchange="e => UpdateSettingValue(setting, e.Value?.ToString() ?? string.Empty)" />
                        }
                    </div>
                </div>
            }
        </div>

        @if (_hasChanges)
        {
            <div class="save-bar">
                <span class="changes-count">
                    <i class="bi bi-pencil-square"></i>
                    @_changedKeys.Count تغيير غير محفوظ
                </span>
                <div class="save-bar-actions">
                    <button class="btn-hb-outline" @onclick="DiscardChanges">
                        <i class="bi bi-x-circle"></i> تراجع
                    </button>
                    <button class="btn-hb-primary" @onclick="SaveChanges" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="hb-spinner-sm"></span>
                        }
                        else
                        {
                            <i class="bi bi-check-circle"></i>
                        }
                        حفظ التغييرات
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<SystemSetting> _settings = [];
    private bool _loading = true;
    private bool _saving;
    private bool _hasChanges;
    private string? _successMessage;
    private string? _errorMessage;
    private string _activeCategory = "General";
    private HashSet<string> _changedKeys = [];
    private Dictionary<string, string> _originalValues = [];

    private static readonly Dictionary<string, string> _categories = new()
    {
        ["General"] = "عام",
        ["Mail"] = "البريد",
        ["Archive"] = "الأرشفة",
        ["Notification"] = "الإشعارات",
        ["Security"] = "الأمان",
        ["Audit"] = "التدقيق"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
        _loading = false;
    }

    private async Task LoadSettings()
    {
        _settings = await DbContext.SystemSettings
            .OrderBy(s => s.Category)
            .ThenBy(s => s.Key)
            .ToListAsync();

        _originalValues = _settings.ToDictionary(s => s.Key, s => s.Value);
        _changedKeys.Clear();
        _hasChanges = false;

        // Default to first available category
        if (_settings.Any() && !_settings.Any(s => s.Category == _activeCategory))
            _activeCategory = _settings.First().Category;
    }

    private void UpdateSettingValue(SystemSetting setting, string newValue)
    {
        setting.Value = newValue;
        _errorMessage = null;
        _successMessage = null;

        if (_originalValues.TryGetValue(setting.Key, out var orig) && orig != newValue)
            _changedKeys.Add(setting.Key);
        else
            _changedKeys.Remove(setting.Key);

        _hasChanges = _changedKeys.Count > 0;
    }

    private void ToggleBool(SystemSetting setting, ChangeEventArgs e)
    {
        var val = (bool)e.Value! ? "true" : "false";
        UpdateSettingValue(setting, val);
    }

    private async Task SaveChanges()
    {
        _saving = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            // Validate int fields
            foreach (var setting in _settings.Where(s => s.ValueType == "int" && _changedKeys.Contains(s.Key)))
            {
                if (!int.TryParse(setting.Value, out var val) || val < 0)
                {
                    _errorMessage = $"القيمة غير صالحة للإعداد: {setting.DescriptionAr}";
                    _saving = false;
                    return;
                }
            }

            await DbContext.SaveChangesAsync();
            SettingService.InvalidateCache();
            _originalValues = _settings.ToDictionary(s => s.Key, s => s.Value);
            _changedKeys.Clear();
            _hasChanges = false;
            _successMessage = "تم حفظ الإعدادات بنجاح";
        }
        catch (Exception)
        {
            _errorMessage = "حدث خطأ أثناء حفظ الإعدادات";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DiscardChanges()
    {
        await LoadSettings();
        _successMessage = null;
        _errorMessage = null;
    }

    private static string GetCategoryIcon(string category) => category switch
    {
        "General" => "bi-gear",
        "Mail" => "bi-file-earmark-text",
        "Archive" => "bi-archive",
        "Notification" => "bi-bell",
        "Security" => "bi-shield-lock",
        "Audit" => "bi-clipboard-data",
        _ => "bi-gear"
    };
}
