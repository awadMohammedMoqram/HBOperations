@page "/mail/compose"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using HBMail.Application.Common.Interfaces
@using HBMail.Domain.Entities
@using HBMail.Domain.Enums
@using HBMail.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject IAppDbContext DbContext
@inject ICurrentUserService CurrentUser
@inject UserManager<ApplicationUser> UserManager
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject INotificationService NotificationService
@inject IFileStorageService FileStorage
@inject IFileValidationService FileValidation
@inject IPdfCompressionService PdfCompression
@inject HBMail.Web.Services.ToastService Toast
@inject ILogger<ComposeMail> Logger

<PageTitle>إرسال بريد جديد - بنك حضرموت</PageTitle>

<div class="page-container hb-fade-in">
    <div class="page-title-section centered-header">
        <div class="centered-title-block">
            <h1 class="section-title"><i class="bi bi-plus-circle"></i> إرسال بريد جديد</h1>
            <p class="section-subtitle">يتم إرسال البريد للمستلم مباشرةً بمجرد الإنشاء</p>
        </div>
    </div>

    <div class="form-layout">
        <div class="hb-card">
            <div class="hb-card-header">
                <h2 class="hb-card-title"><i class="bi bi-file-earmark-plus"></i> بيانات البريد</h2>
            </div>

            <EditForm Model="_model" OnSubmit="HandleSubmit" FormName="CreateTransaction">
                <div class="form-grid">
                    <div class="hb-form-group full-width sender-info-banner">
                        <label class="hb-form-label">
                            <i class="bi bi-person-badge"></i> المرسل
                        </label>
                        <div class="sender-readonly">
                            <span class="sender-name">@(CurrentUser.FullName ?? CurrentUser.UserName)</span>
                            @if (_currentBranchName is not null)
                            {
                                <span class="sender-meta"><i class="bi bi-building"></i> @_currentBranchName</span>
                            }
                            @if (_currentDepartmentName is not null)
                            {
                                <span class="sender-meta"><i class="bi bi-diagram-3"></i> @_currentDepartmentName</span>
                            }
                        </div>
                    </div>

                    <div class="hb-form-group full-width">
                        <label class="hb-form-label">الموضوع <span class="required-star">*</span></label>
                        <InputText @bind-Value="_model.Subject" class="hb-form-control" placeholder="أدخل موضوع البريد" />
                    </div>

                    <div class="hb-form-group full-width">
                        <label class="hb-form-label">الوصف</label>
                        <InputTextArea @bind-Value="_model.Description" class="hb-form-control textarea" rows="3"
                                       placeholder="وصف تفصيلي للبريد (اختياري)" />
                    </div>

                    <div class="hb-form-group">
                        <label class="hb-form-label">نوع البريد <span class="required-star">*</span></label>
                        <InputSelect @bind-Value="_model.Type" class="hb-form-control">
                            @foreach (var t in Enum.GetValues<MailType>())
                            {
                                <option value="@t">@GetTypeLabel(t)</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="hb-form-group">
                        <label class="hb-form-label">الأولوية <span class="required-star">*</span></label>
                        <InputSelect @bind-Value="_model.Priority" class="hb-form-control">
                            @foreach (var p in Enum.GetValues<MailPriority>())
                            {
                                <option value="@p">@GetPriorityLabel(p)</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="hb-form-group">
                        <label class="hb-form-label">الفرع المستلِم <span class="required-star">*</span></label>
                        <InputSelect @bind-Value="_model.ReceiverBranchId" class="hb-form-control"
                                     @bind-Value:after="OnReceiverBranchChanged">
                            <option value="">-- اختر الفرع --</option>
                            @foreach (var b in _branches)
                            {
                                <option value="@b.Id">@b.NameAr</option>
                            }
                        </InputSelect>
                    </div>

                    @if (_isHqSelected)
                    {
                        <div class="hb-form-group">
                            <label class="hb-form-label">الإدارة المستلِمة <span class="required-star">*</span></label>
                            <InputSelect @bind-Value="_model.ReceiverDepartmentId" class="hb-form-control"
                                         @bind-Value:after="OnReceiverDepartmentChanged">
                                <option value="">-- اختر الإدارة --</option>
                                @foreach (var d in _departments)
                                {
                                    <option value="@d.Id">@d.NameAr</option>
                                }
                            </InputSelect>
                        </div>
                    }

                    <div class="hb-form-group">
                        <label class="hb-form-label">الشخص المستلِم <span class="required-star">*</span></label>
                        <InputSelect @bind-Value="_model.ReceiverUserId" class="hb-form-control" disabled="@(_receiverUsers.Count == 0)">
                            <option value="">@GetReceiverPlaceholder()</option>
                            @foreach (var u in _receiverUsers)
                            {
                                <option value="@u.Id">@u.FullNameAr @(string.IsNullOrEmpty(u.JobTitle) ? "" : $"— {u.JobTitle}")</option>
                            }
                        </InputSelect>
                        <small class="hb-form-help">@GetReceiverHelp()</small>
                    </div>

                    <div class="hb-form-group full-width">
                        <label class="hb-form-label">
                            <i class="bi bi-people"></i> نسخة إلى (CC) <span class="optional-badge">اختياري</span>
                        </label>
                        <div class="cc-multiselect">
                            <div class="cc-input-area" @onclick="() => _ccDropdownOpen = true">
                                @if (_selectedCcIds.Count > 0)
                                {
                                    @foreach (var ccId in _selectedCcIds)
                                    {
                                        var user = _ccCandidates.FirstOrDefault(u => u.Id == ccId);
                                        if (user != null)
                                        {
                                            <span class="cc-tag">
                                                @user.FullNameAr
                                                <button type="button" class="cc-tag-remove" @onclick="() => RemoveCc(ccId)" @onclick:stopPropagation="true"><i class="bi bi-x"></i></button>
                                            </span>
                                        }
                                    }
                                }
                                <input type="text" class="cc-search-input" placeholder="@(_selectedCcIds.Count == 0 ? "ابحث واختر أشخاص..." : "ابحث...")"
                                       @bind="_ccSearchTerm" @bind:event="oninput"
                                       @onfocus="() => _ccDropdownOpen = true" />
                            </div>
                            @if (_ccDropdownOpen)
                            {
                                <div class="cc-dropdown-backdrop" @onclick="() => _ccDropdownOpen = false"></div>
                                <div class="cc-dropdown">
                                    @{ var filtered = GetFilteredCcCandidates(); }
                                    @if (!filtered.Any())
                                    {
                                        <div class="cc-dropdown-empty">لا توجد نتائج</div>
                                    }
                                    else
                                    {
                                        @foreach (var u in filtered)
                                        {
                                            var isSelected = _selectedCcIds.Contains(u.Id);
                                            <div class="cc-dropdown-item @(isSelected ? "selected" : "")" @onclick="() => ToggleCcUser(u.Id)">
                                                <i class="bi @(isSelected ? "bi-check-square-fill" : "bi-square")"></i>
                                                <span class="cc-dropdown-name">@u.FullNameAr</span>
                                                @if (!string.IsNullOrEmpty(u.JobTitle))
                                                {
                                                    <span class="cc-dropdown-role">— @u.JobTitle</span>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        </div>
                        <small class="hb-form-help">ابحث بالاسم واختر أكثر من شخص. سيحصلون على إشعار + قراءة فقط.</small>
                    </div>

                    <div class="hb-form-group">
                        <label class="hb-form-label">
                            <i class="bi bi-clock-history"></i> تاريخ الإرسال الفعلي <span class="required-star">*</span>
                        </label>
                        <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="_model.SentAt" class="hb-form-control" />
                        <small class="hb-form-help">أدخل وقت الإرسال الفعلي للبريد (وليس وقت إنشائها على النظام).</small>
                    </div>

                    <div class="hb-form-group">
                        <label class="hb-form-label">تاريخ الاستحقاق (اختياري)</label>
                        <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="_model.DueDate" class="hb-form-control" />
                    </div>

                    <div class="hb-form-group full-width require-doc-toggle">
                        <label class="toggle-label">
                            <InputCheckbox @bind-Value="_model.RequireReceiverDocument" />
                            <span class="toggle-text">
                                <strong><i class="bi bi-file-earmark-check"></i> اشتراط رفع مستند إثبات استلام</strong>
                                <small>عند التفعيل، لن يستطيع المستلم تأكيد الاستلام دون رفع مستند إثبات.</small>
                            </span>
                        </label>
                    </div>

                    <div class="hb-form-group full-width">
                        <label class="hb-form-label">
                            <i class="bi bi-chat-left-text"></i> ملاحظة المرسل (اختياري)
                        </label>
                        <InputTextArea @bind-Value="_model.SenderNote" class="hb-form-control textarea" rows="2"
                                       maxlength="1000"
                                       placeholder="أي ملاحظة تود إرسالها للمستلم مع البريد..." />
                        <small class="hb-form-help">ستظهر للمستلم في صفحة تفاصيل البريد.</small>
                    </div>

                    <div class="hb-form-group full-width">
                        <label class="hb-form-label">
                            <i class="bi bi-paperclip"></i> المرفقات (اختياري)
                        </label>
                        <div class="upload-dropzone @(_pendingFiles.Count > 0 ? "has-files" : "") @(_uploadingFile ? "is-uploading" : "")">
                            <InputFile OnChange="HandleFilesSelected"
                                       accept=".pdf"
                                       class="upload-input" id="createTxUpload"
                                       disabled="@_uploadingFile" />
                            <label for="createTxUpload" class="upload-dropzone-inner">
                                <div class="upload-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                                <div class="upload-title">انقر لاختيار ملف PDF</div>
                                <div class="upload-hint">PDF فقط — ملف واحد، حجم الملف حتى 5 ميجا</div>
                            </label>
                            @if (_uploadingFile)
                            {
                                <div class="upload-loading-overlay">
                                    <div class="upload-loading-content">
                                        <div class="hb-spinner upload-spinner"></div>
                                        <div class="upload-loading-title">جارٍ قراءة الملف...</div>
                                        <div class="upload-loading-hint">يرجى الانتظار قليلاً</div>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (_pendingFiles.Count > 0)
                        {
                            <div class="pending-files-card">
                                <div class="pending-files-header">
                                    <span><i class="bi bi-files"></i> الملفات المختارة (@_pendingFiles.Count)</span>
                                    <button type="button" class="pending-clear-btn" @onclick="ClearPendingFiles">
                                        <i class="bi bi-x-circle"></i> مسح الكل
                                    </button>
                                </div>
                                <ul class="pending-files-list">
                                    @for (var i = 0; i < _pendingFiles.Count; i++)
                                    {
                                        var idx = i;
                                        var f = _pendingFiles[idx];
                                        <li class="pending-file-item">
                                            <div class="pf-icon"><i class="bi @GetFileIcon(f.Name)"></i></div>
                                            <div class="pf-info">
                                                <span class="pf-name">@f.Name</span>
                                                <span class="pf-size">@FormatSize(f.Size)</span>
                                            </div>
                                            <button type="button" class="pf-remove" title="إزالة"
                                                    @onclick="() => RemovePendingFile(idx)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </div>

                <div class="form-actions form-actions-inline">
                    <a href="/mail" class="btn-hb-outline btn-sm">
                        <i class="bi bi-x-lg"></i> إلغاء
                    </a>
                    <button type="submit" class="btn-hb-primary btn-sm" disabled="@_submitting">
                        @if (_submitting)
                        {
                            <span class="hb-spinner" style="width:16px;height:16px;border-width:2px;"></span>
                            <span>جاري الإرسال...</span>
                        }
                        else
                        {
                            <i class="bi bi-send-fill"></i>
                            <span>إرسال البريد</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private readonly ComposeMailModel _model = new();
    private List<Branch> _branches = [];
    private List<Department> _departments = [];
    private List<ApplicationUser> _receiverUsers = [];
    private List<ApplicationUser> _ccCandidates = [];
    private List<Guid> _selectedCcIds = [];
    private string _ccSearchTerm = "";
    private bool _ccDropdownOpen;
    private string? _currentBranchName;
    private string? _currentDepartmentName;
    private bool _submitting;
    private bool _uploadingFile;
    private Guid? _hqBranchId;
    private bool _isHqSelected;
    private readonly List<PendingFile> _pendingFiles = new();
    private const int MaxFiles = 1;
    private const long MaxOriginalBytes = 20L * 1024 * 1024;     // hard ceiling on the upload size we accept into memory
    private const long MaxCompressedBytes = 5L * 1024 * 1024;    // post-compression cap enforced server-side too

    private long PendingTotalBytes => _pendingFiles.Sum(f => f.Size);

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        _uploadingFile = true;
        StateHasChanged();
        try
        {
            Logger.LogInformation("HandleFilesSelected fired with {Count} file(s)", e.FileCount);
            foreach (var file in e.GetMultipleFiles(MaxFiles))
            {
                Logger.LogInformation("Processing file Name={Name} Size={Size} ContentType={CT}",
                    file.Name, file.Size, file.ContentType);
                if (_pendingFiles.Count >= MaxFiles)
                {
                    await SafeToast("الحد الأقصى", "يُسمح برفع ملف واحد فقط لكل مستخدم.", "warning");
                    break;
                }
                var ext = System.IO.Path.GetExtension(file.Name).ToLowerInvariant();
                if (ext != ".pdf")
                {
                    await SafeToast("نوع غير مسموح", $"الملف '{file.Name}' غير مدعوم — يُقبل PDF فقط", "warning");
                    continue;
                }
                if (file.Size > MaxOriginalBytes)
                {
                    await SafeToast("تجاوز الحجم", $"حجم '{file.Name}' أكبر من 20 ميجا. يجب تصغيره قبل الرفع.", "warning");
                    continue;
                }
                try
                {
                    using var ms = new MemoryStream();
                    await file.OpenReadStream(MaxOriginalBytes).CopyToAsync(ms);
                    Logger.LogInformation("File buffered into memory: {Bytes} bytes", ms.Length);
                    _pendingFiles.Add(new PendingFile
                    {
                        Name = file.Name,
                        ContentType = string.IsNullOrEmpty(file.ContentType) ? "application/pdf" : file.ContentType,
                        Size = file.Size,
                        Data = ms.ToArray()
                    });
                }
                catch (Exception innerEx)
                {
                    Logger.LogError(innerEx, "OpenReadStream failed for {Name}", file.Name);
                    await SafeToast("تعذّر قراءة الملف",
                        $"لم يتمكّن التطبيق من قراءة '{file.Name}': {innerEx.Message}");
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "HandleFilesSelected outer failure");
            await SafeToast("فشل الرفع", $"تعذّر استلام الملف: {ex.Message}");
        }
        finally
        {
            _uploadingFile = false;
            StateHasChanged();
        }
    }

    private void RemovePendingFile(int index)
    {
        if (index >= 0 && index < _pendingFiles.Count)
            _pendingFiles.RemoveAt(index);
    }

    private void ClearPendingFiles() => _pendingFiles.Clear();

    private static string GetFileIcon(string name)
    {
        var ext = Path.GetExtension(name).ToLowerInvariant();
        return ext switch
        {
            ".pdf" => "bi-file-earmark-pdf",
            ".doc" or ".docx" => "bi-file-earmark-word",
            ".xls" or ".xlsx" => "bi-file-earmark-excel",
            ".png" or ".jpg" or ".jpeg" or ".gif" => "bi-file-earmark-image",
            _ => "bi-file-earmark"
        };
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private class PendingFile
    {
        public string Name { get; set; } = "";
        public string ContentType { get; set; } = "";
        public long Size { get; set; }
        public byte[] Data { get; set; } = Array.Empty<byte>();
    }

    protected override async Task OnInitializedAsync()
    {
        // فقط الشؤون الإدارية (DEP-ADM) أو SuperAdmin/ITAdmin يمكنهم إنشاء بريد
        var globalRoles = new[] { "SuperAdmin", "ITAdmin" };
        var hasGlobalAccess = globalRoles.Any(r => CurrentUser.IsInRole(r));

        if (!hasGlobalAccess)
        {
            var isAdminAffairs = false;
            if (CurrentUser.DepartmentId.HasValue)
            {
                isAdminAffairs = await DbContext.Departments.AsNoTracking()
                    .AnyAsync(d => d.Id == CurrentUser.DepartmentId.Value && d.Code == "DEP-ADM");
            }
            if (!isAdminAffairs)
            {
                Navigation.NavigateTo("/mail", replace: true);
                return;
            }
        }

        _branches = await DbContext.Branches
            .Where(b => b.IsActive)
            .OrderBy(b => b.NameAr)
            .ToListAsync();

        _hqBranchId = _branches.FirstOrDefault(b => b.BranchType == BranchType.HeadOffice)?.Id;

        _departments = await DbContext.Departments
            .Where(d => d.IsActive)
            .OrderBy(d => d.NameAr)
            .ToListAsync();

        if (CurrentUser.BranchId.HasValue)
        {
            _currentBranchName = _branches.FirstOrDefault(b => b.Id == CurrentUser.BranchId.Value)?.NameAr;
        }
        if (CurrentUser.DepartmentId.HasValue)
        {
            _currentDepartmentName = _departments.FirstOrDefault(d => d.Id == CurrentUser.DepartmentId.Value)?.NameAr;
        }

        await LoadCcCandidates();
    }

    private async Task OnReceiverBranchChanged()
    {
        _model.ReceiverUserId = null;
        _model.ReceiverDepartmentId = null;
        _receiverUsers = [];
        _isHqSelected = false;

        if (string.IsNullOrEmpty(_model.ReceiverBranchId)) return;
        if (!Guid.TryParse(_model.ReceiverBranchId, out var branchId)) return;

        // إذا اختار الإدارة العامة → ننتظر اختيار الإدارة لتحميل المستخدمين
        if (_hqBranchId.HasValue && branchId == _hqBranchId.Value)
        {
            _isHqSelected = true;
            return;
        }

        // فرع عادي → موظفو هذا الفرع فقط
        _receiverUsers = await UserManager.Users
            .Where(u => u.IsActive
                        && u.BranchId == branchId
                        && u.Id != CurrentUser.UserId)
            .OrderBy(u => u.FullNameAr)
            .ToListAsync();

        await LoadCcCandidates();
    }

    private async Task OnReceiverDepartmentChanged()
    {
        _model.ReceiverUserId = null;
        _receiverUsers = [];

        if (string.IsNullOrEmpty(_model.ReceiverDepartmentId)) return;
        if (!Guid.TryParse(_model.ReceiverDepartmentId, out var deptId)) return;
        if (!_hqBranchId.HasValue) return;

        // موظفو HQ في الإدارة المختارة
        _receiverUsers = await UserManager.Users
            .Where(u => u.IsActive
                        && u.BranchId == _hqBranchId.Value
                        && u.DepartmentId == deptId
                        && u.Id != CurrentUser.UserId)
            .OrderBy(u => u.FullNameAr)
            .ToListAsync();

        await LoadCcCandidates();
    }

    private async Task LoadCcCandidates()
    {
        // CC candidates = all active users except sender
        _ccCandidates = await UserManager.Users
            .Where(u => u.IsActive && u.Id != CurrentUser.UserId)
            .OrderBy(u => u.FullNameAr)
            .ToListAsync();

        // Remove any CC selections that are no longer valid
        _selectedCcIds.RemoveAll(id => !_ccCandidates.Any(u => u.Id == id));
    }

    private void ToggleCcUser(Guid userId)
    {
        if (_selectedCcIds.Contains(userId))
            _selectedCcIds.Remove(userId);
        else
            _selectedCcIds.Add(userId);
        _ccSearchTerm = "";
    }

    private IEnumerable<ApplicationUser> GetFilteredCcCandidates()
    {
        if (string.IsNullOrWhiteSpace(_ccSearchTerm))
            return _ccCandidates;

        return _ccCandidates.Where(u =>
            (u.FullNameAr?.Contains(_ccSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (u.JobTitle?.Contains(_ccSearchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private void RemoveCc(Guid userId) => _selectedCcIds.Remove(userId);

    private string GetReceiverPlaceholder()
    {
        if (string.IsNullOrEmpty(_model.ReceiverBranchId)) return "-- اختر الفرع أولاً --";
        if (_isHqSelected && string.IsNullOrEmpty(_model.ReceiverDepartmentId)) return "-- اختر الإدارة أولاً --";
        if (_receiverUsers.Count == 0) return "-- لا يوجد موظفون --";
        return "-- اختر المستلِم --";
    }

    private string GetReceiverHelp()
    {
        if (_isHqSelected) return "موظفو الإدارة المختارة في الإدارة العامة";
        if (!string.IsNullOrEmpty(_model.ReceiverBranchId)) return "";
        return "اختر الفرع المستلِم لعرض الموظفين";
    }

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private async Task SafeToast(string title, string message, string level = "error")
    {
        // على الموبايل قد تكون دائرة SignalR معلّقة أثناء عملية رفع كبيرة، لذلك نحمي كل استدعاء Toast بـ try/catch.
        try
        {
            switch (level)
            {
                case "warning": await Toast.ShowWarningAsync(title, message); break;
                case "info":    await Toast.ShowInfoAsync(title, message); break;
                default:        await Toast.ShowErrorAsync(title, message); break;
            }
        }
        catch (Exception toastEx)
        {
            Logger.LogWarning(toastEx, "Toast failed: {Title} - {Message}", title, message);
        }
    }

    private async Task HandleSubmit()
    {
        _submitting = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_model.Subject))
            {
                await Toast.ShowErrorAsync("يرجى إدخال موضوع البريد");
                return;
            }

            if (string.IsNullOrEmpty(_model.ReceiverBranchId))
            {
                await Toast.ShowErrorAsync("يرجى اختيار الفرع المستلِم");
                return;
            }

            if (_isHqSelected && string.IsNullOrEmpty(_model.ReceiverDepartmentId))
            {
                await Toast.ShowErrorAsync("يرجى اختيار الإدارة المستلِمة");
                return;
            }

            if (string.IsNullOrEmpty(_model.ReceiverUserId))
            {
                await Toast.ShowErrorAsync("يرجى اختيار الشخص المستلِم");
                return;
            }

            if (_model.DueDate.HasValue && _model.DueDate.Value.Date < AppTime.YemenNow.Date)
            {
                await Toast.ShowErrorAsync("تاريخ الاستحقاق لا يمكن أن يكون في الماضي");
                return;
            }

            // وقت الإرسال الفعلي — يدخله المستخدم بتوقيت اليمن، نحوّله إلى UTC للتخزين
            var sentAtUtc = AppTime.FromYemenToUtc(_model.SentAt);

            var receiverUserId = Guid.Parse(_model.ReceiverUserId!);
            var receiverUser = _receiverUsers.FirstOrDefault(u => u.Id == receiverUserId);
            if (receiverUser is null)
            {
                await Toast.ShowErrorAsync("الشخص المستلِم المختار غير صالح");
                return;
            }

            var now = DateTime.UtcNow;
            var prefix = $"hb-{now:yyyyMM}-";
            var lastRef = await DbContext.Mails
                .Where(t => t.ReferenceNumber.StartsWith(prefix))
                .OrderByDescending(t => t.ReferenceNumber)
                .Select(t => t.ReferenceNumber)
                .FirstOrDefaultAsync();
            var seq = 1;
            if (lastRef is not null && int.TryParse(lastRef[prefix.Length..], out var lastSeq))
                seq = lastSeq + 1;
            var refNumber = $"{prefix}{seq:D5}";

            var nowUtc = DateTime.UtcNow;
            var Mail = new Mail
            {
                Id = Guid.NewGuid(),
                ReferenceNumber = refNumber,
                Subject = _model.Subject.Trim(),
                Description = string.IsNullOrWhiteSpace(_model.Description) ? null : _model.Description.Trim(),
                Type = _model.Type,
                Priority = _model.Priority,
                Status = MailStatus.Sent,
                SenderUserId = CurrentUser.UserId,
                SenderBranchId = CurrentUser.BranchId,
                SenderDepartmentId = CurrentUser.DepartmentId,
                ReceiverBranchId = Guid.Parse(_model.ReceiverBranchId!),
                ReceiverDepartmentId = receiverUser.DepartmentId,
                ReceiverUserId = receiverUserId,
                RequireReceiverDocument = _model.RequireReceiverDocument,
                SenderNote = string.IsNullOrWhiteSpace(_model.SenderNote) ? null : _model.SenderNote.Trim(),
                DueDate = _model.DueDate,
                SentAt = sentAtUtc,
                CreatedAt = nowUtc,
                CreatedByUserId = CurrentUser.UserId
            };

            Mail.History.Add(new MailHistory
            {
                MailId = Mail.Id,
                FromStatus = MailStatus.Sent,
                ToStatus = MailStatus.Sent,
                Action = "تم إرسال البريد",
                PerformedByUserId = CurrentUser.UserId,
                PerformedAt = nowUtc
            });

            DbContext.Mails.Add(Mail);
            await DbContext.SaveChangesAsync();

            // رفع المرفق الاختياري للمرسل (ملف واحد كحد أقصى)
            if (_pendingFiles.Count > 0)
            {
                var pf = _pendingFiles[0];
                Logger.LogInformation("Upload start TxId={TxId} File={Name} Size={Size}",
                    Mail.Id, pf.Name, pf.Size);
                try
                {
                    using var validateStream = new MemoryStream(pf.Data);
                    var validation = FileValidation.Validate(validateStream, pf.Name, pf.ContentType, pf.Size);
                    if (!validation.IsValid)
                    {
                        Logger.LogWarning("File validation failed: {Reason}", validation.ErrorMessage);
                        await SafeToast("ملف غير صالح", $"'{pf.Name}': {validation.ErrorMessage}", "warning");
                    }
                    else
                    {
                        Logger.LogInformation("Compressing PDF {Name} ({Bytes} bytes)", pf.Name, pf.Size);
                        using var compressInput = new MemoryStream(pf.Data);
                        var compression = await PdfCompression.CompressAsync(compressInput);
                        Logger.LogInformation("Compression done: {Original} -> {Compressed} ({Ratio:P0})",
                            compression.OriginalSizeBytes, compression.CompressedSizeBytes,
                            compression.OriginalSizeBytes > 0
                                ? 1.0 - (double)compression.CompressedSizeBytes / compression.OriginalSizeBytes
                                : 0);

                        if (compression.CompressedSizeBytes > MaxCompressedBytes)
                        {
                            compression.OutputStream.Dispose();
                            var sizeMb = compression.CompressedSizeBytes / (1024.0 * 1024.0);
                            Logger.LogWarning("Compressed file exceeds cap: {SizeMb:F2} MB", sizeMb);
                            await SafeToast(
                                "تجاوز حد الحجم",
                                $"حجم الملف بعد الضغط ({sizeMb:F2} ميجا) يتجاوز الحد المسموح (5 ميجا).");
                        }
                        else
                        {
                            await using var uploadStream = compression.OutputStream;
                            uploadStream.Position = 0;
                            var uploadResult = await FileStorage.UploadAsync(uploadStream, pf.Name, pf.ContentType);
                            Logger.LogInformation("File stored at {Path} ({Bytes} bytes)",
                                uploadResult.StoragePath, uploadResult.FileSizeBytes);

                            var doc = new MailAttachment
                            {
                                Id = Guid.NewGuid(),
                                MailId = Mail.Id,
                                OriginalFileName = pf.Name,
                                StoragePath = uploadResult.StoragePath,
                                FileSizeBytes = uploadResult.FileSizeBytes,
                                Checksum = uploadResult.Checksum,
                                ContentType = pf.ContentType,
                                AttachmentType = AttachmentType.Attachment,
                                Version = 1,
                                UploadedByUserId = CurrentUser.UserId,
                                UploadedAt = DateTime.UtcNow
                            };
                            DbContext.MailAttachments.Add(doc);
                            await DbContext.SaveChangesAsync();
                            Logger.LogInformation("Document {DocId} saved to DB", doc.Id);
                        }
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Upload failed for TxId={TxId} File={Name}", Mail.Id, pf.Name);
                    await SafeToast("فشل رفع المرفق", ex.Message);
                    // لا نقطع العملية — البريد تم إنشاؤها بنجاح، فقط المرفق فشل.
                }
            }

            try
            {
                var title = $"بريد جديد وارد — {Mail.ReferenceNumber}";
                var message = $"بريد جديد من {_currentBranchName ?? "الإدارة"} بعنوان: {Mail.Subject}";

                // إشعار المستلم
                if (receiverUserId != CurrentUser.UserId)
                {
                    await NotificationService.NotifyUserAsync(
                        receiverUserId, title, message, Mail.Id, NotificationType.MailCreated);
                }

                // إشعار المدير تلقائياً (إذا المستلم موظف وليس مدير)
                var receiverRoles = await UserManager.GetRolesAsync(receiverUser);
                var isReceiverManager = receiverRoles.Any(r => r is "DepartmentManager" or "BranchManager" or "OfficeManager");
                if (!isReceiverManager && receiverUser.DepartmentId.HasValue)
                {
                    // ابحث عن مدير في نفس الإدارة
                    var managerRole = await UserManager.GetUsersInRoleAsync("DepartmentManager");
                    var deptManager = managerRole.FirstOrDefault(u => u.DepartmentId == receiverUser.DepartmentId && u.IsActive && u.Id != receiverUserId);
                    if (deptManager != null)
                    {
                        Mail.ManagerNotifiedUserId = deptManager.Id;
                        DbContext.Mails.Update(Mail);
                        await DbContext.SaveChangesAsync();

                        await NotificationService.NotifyUserAsync(
                            deptManager.Id,
                            $"بريد أُرسل لموظفك — {Mail.ReferenceNumber}",
                            $"تم إرسال بريد '{Mail.Subject}' لموظفك {receiverUser.FullNameAr}.",
                            Mail.Id, NotificationType.MailCreated);
                    }
                }

                // إشعار CC
                if (_selectedCcIds.Count > 0)
                {
                    // Save CC records
                    foreach (var ccUserId in _selectedCcIds)
                    {
                        DbContext.MailCCs.Add(new MailCC
                        {
                            Id = Guid.NewGuid(),
                            MailId = Mail.Id,
                            UserId = ccUserId,
                            AddedAt = DateTime.UtcNow
                        });
                    }
                    await DbContext.SaveChangesAsync();

                    // Notify each CC user
                    foreach (var ccUserId in _selectedCcIds.Where(id => id != CurrentUser.UserId))
                    {
                        try
                        {
                            await NotificationService.NotifyUserAsync(
                                ccUserId,
                                $"نسخة: {Mail.ReferenceNumber}",
                                $"تم إدراجك في نسخة بريد '{Mail.Subject}'.",
                                Mail.Id, NotificationType.MailCreated);
                        }
                        catch { }
                    }
                }
            }
            catch
            {
            }

            Navigation.NavigateTo($"/mail/{Mail.Id}?success={Uri.EscapeDataString($"تم إرسال البريد بنجاح — رقم المرجع: {refNumber}")}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "HandleSubmit failed");
            await SafeToast("حدث خطأ", ex.Message);
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string GetTypeLabel(MailType t) => t switch
    {
        MailType.DocumentDelivery => "تسليم مرفقات",
        MailType.CashTransfer => "تحويل نقدي",
        MailType.InternalDepartment => "داخلي بين الإدارات",
        MailType.BranchToBranch => "بين الفروع",
        MailType.Other => "أخرى",
        _ => t.ToString()
    };

    private static string GetPriorityLabel(MailPriority p) => p switch
    {
        MailPriority.Normal => "عادية",
        MailPriority.Important => "مهمة",
        MailPriority.Urgent => "عاجلة",
        _ => p.ToString()
    };

    private class ComposeMailModel
    {
        public string Subject { get; set; } = "";
        public string? Description { get; set; }
        public MailType Type { get; set; } = MailType.DocumentDelivery;
        public MailPriority Priority { get; set; } = MailPriority.Normal;
        public string? ReceiverBranchId { get; set; }
        public string? ReceiverDepartmentId { get; set; }
        public string? ReceiverUserId { get; set; }
        public DateTime? DueDate { get; set; }
        public DateTime SentAt { get; set; } = AppTime.YemenNow;
        public bool RequireReceiverDocument { get; set; }
        public string? SenderNote { get; set; }
    }
}
