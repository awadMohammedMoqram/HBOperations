@page "/mail"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using HBMail.Application.Common.Interfaces
@using HBMail.Application.Workflow
@using HBMail.Domain.Enums
@using HBMail.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject IAppDbContext DbContext
@inject ICurrentUserService CurrentUser
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject MailStateMachine StateMachine
@inject INotificationService NotificationService

<PageTitle>صندوق البريد - بنك حضرموت</PageTitle>

<div class="page-container hb-fade-in">
    <!-- Page Header -->
    <div class="page-title-section">
        <div class="title-with-action">
            <div>
                <h1 class="section-title"><i class="bi bi-file-earmark-text"></i> صندوق البريد</h1>
                <p class="section-subtitle">عرض وإدارة جميع البريد الواردة والصادرة</p>
            </div>
            @if (_canCompose)
            {
                <a href="/mail/compose" class="btn-hb-primary btn-add-Mail">
                    <i class="bi bi-plus-circle"></i> بريد جديد
                </a>
            }
        </div>
    </div>

    <!-- Filters -->
    <div class="hb-card filter-card">
        <div class="filters-row">
            <div class="filter-group">
                <label class="hb-form-label">بحث</label>
                <input type="text" class="hb-form-control" placeholder="رقم المرجع أو الموضوع..."
                       @bind="_searchTerm" @bind:event="oninput" />
            </div>
            <div class="filter-group">
                <label class="hb-form-label">الحالة</label>
                <select class="hb-form-control" @bind="_statusFilter">
                    <option value="">الكل</option>
                    @foreach (var status in Enum.GetValues<MailStatus>())
                    {
                        <option value="@status">@GetStatusLabel(status)</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label class="hb-form-label">النوع</label>
                <select class="hb-form-control" @bind="_typeFilter">
                    <option value="">الكل</option>
                    @foreach (var type in Enum.GetValues<MailType>())
                    {
                        <option value="@type">@GetTypeLabel(type)</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label class="hb-form-label">الأولوية</label>
                <select class="hb-form-control" @bind="_priorityFilter">
                    <option value="">الكل</option>
                    @foreach (var priority in Enum.GetValues<MailPriority>())
                    {
                        <option value="@priority">@GetPriorityLabel(priority)</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar">
        <div class="stat-item">
            <i class="bi bi-file-earmark-text"></i>
            <span class="stat-number">@_totalCount</span>
            <span class="stat-label">إجمالي</span>
        </div>
        <div class="stat-item stat-pending">
            <i class="bi bi-send"></i>
            <span class="stat-number">@_pendingCount</span>
            <span class="stat-label">بانتظار الاستلام</span>
        </div>
        <div class="stat-item stat-completed">
            <i class="bi bi-check-circle"></i>
            <span class="stat-number">@_completedCount</span>
            <span class="stat-label">مستلمة / مؤرشفة</span>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="hb-alert hb-alert-success">
            <i class="bi bi-check-circle-fill"></i> @_successMessage
        </div>
    }

    <!-- Table -->
    @if (_loading)
    {
        <div class="hb-loading">
            <div class="hb-spinner"></div>
            <span>جاري تحميل البريد...</span>
        </div>
    }
    else if (!_Mails.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h3>لا توجد بريد</h3>
            <p>لم يتم العثور على بريد تطابق معايير البحث</p>
        </div>
    }
    else
    {
        <div class="table-container">
            <table class="hb-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>رقم المرجع</th>
                        <th>الموضوع</th>
                        <th>النوع</th>
                        <th>من</th>
                        <th>إلى</th>
                        <th>الأولوية</th>
                        <th>الحالة</th>
                        <th>التاريخ</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var index = 0; }
                    @foreach (var t in GetFilteredMails())
                    {
                        index++;
                        <tr>
                            <td data-label="#">@index</td>
                            <td data-label="رقم المرجع"><span class="ref-number">@t.ReferenceNumber</span></td>
                            <td data-label="الموضوع" class="subject-cell">
                                @t.Subject
                                @if (_ccMailIds.Contains(t.Id))
                                {
                                    <span class="cc-badge" title="أنت في نسخة هذا البريد"><i class="bi bi-eye"></i> نسخة</span>
                                }
                                @if (t.ManagerNotifiedUserId == CurrentUser.UserId && !_ccMailIds.Contains(t.Id))
                                {
                                    <span class="cc-badge manager-badge" title="إشعار تلقائي — بريد موظفك"><i class="bi bi-bell"></i> إشعار مدير</span>
                                }
                            </td>
                            <td data-label="النوع"><span class="hb-badge hb-badge-primary">@GetTypeLabel(t.Type)</span></td>
                            <td data-label="من">@(t.SenderBranch?.NameAr ?? "—")</td>
                            <td data-label="إلى">@(t.ReceiverBranch?.NameAr ?? "—")</td>
                            <td data-label="الأولوية">
                                <span class="hb-badge priority-badge @GetPriorityBadgeClass(t.Priority)">
                                    <i class="@GetPriorityIcon(t.Priority)"></i>
                                    <span>@GetPriorityLabel(t.Priority)</span>
                                </span>
                            </td>
                            <td data-label="الحالة">
                                <span class="status-badge @GetStatusClass(t.Status)">
                                    <i class="@GetStatusIcon(t.Status)"></i>
                                    @GetStatusLabel(t.Status)
                                </span>
                            </td>
                            <td data-label="التاريخ" class="date-cell">@AppTime.FormatYemen(t.CreatedAt, "yyyy/MM/dd")</td>
                            <td data-label="إجراءات">
                                <div class="action-buttons">
                                    <a href="/mail/@t.Id" class="action-btn view" title="عرض التفاصيل">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @{
                                        var isReceiverOnly = IsReceiverOnly(t);
                                        var isSender = IsSenderFor(t);
                                        var canEdit = isSender && t.Status == MailStatus.Sent;
                                        var canReject = isReceiverOnly && t.Status == MailStatus.AssignedToStaff;
                                    }
                                    @if (canEdit)
                                    {
                                        <a href="/mail/edit/@t.Id" class="action-btn edit" title="تعديل">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                    }
                                    @if (canReject)
                                    {
                                        <button class="action-btn reject" title="رفض البريد" @onclick="() => OpenRejectModal(t)">
                                            <i class="bi bi-x-octagon"></i>
                                        </button>
                                    }
                                    @if (isSender)
                                    {
                                        <button class="action-btn delete" title="حذف" @onclick="() => OpenDeleteModal(t)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Pagination *@
        @if (_totalPages > 1)
        {
            <div class="pagination-container">
                <div class="pagination-info">
                    عرض @((_currentPage - 1) * _pageSize + 1) - @Math.Min(_currentPage * _pageSize, _filteredCount) من @_filteredCount
                </div>
                <div class="pagination-controls">
                    <button class="page-btn" disabled="@(_currentPage <= 1)" @onclick="() => GoToPage(1)">
                        <i class="bi bi-chevron-double-right"></i>
                    </button>
                    <button class="page-btn" disabled="@(_currentPage <= 1)" @onclick="() => GoToPage(_currentPage - 1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                    @foreach (var p in GetPageNumbers())
                    {
                        <button class="page-btn @(p == _currentPage ? "active" : "")" @onclick="() => GoToPage(p)">@p</button>
                    }
                    <button class="page-btn" disabled="@(_currentPage >= _totalPages)" @onclick="() => GoToPage(_currentPage + 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <button class="page-btn" disabled="@(_currentPage >= _totalPages)" @onclick="() => GoToPage(_totalPages)">
                        <i class="bi bi-chevron-double-left"></i>
                    </button>
                </div>
            </div>
        }
    }
</div>

@* ===== Delete Confirmation Modal ===== *@
@if (_showDeleteModal)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="modal-content modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header modal-header-danger">
                <h3><i class="bi bi-exclamation-triangle"></i> تأكيد الحذف</h3>
                <button class="modal-close" @onclick="CloseDeleteModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_deleteError))
                {
                    <div class="hb-alert hb-alert-danger" style="margin-bottom:1rem;">
                        <i class="bi bi-exclamation-triangle-fill"></i> @_deleteError
                    </div>
                }
                <p class="delete-message">هل أنت متأكد من حذف البريد <strong>@_deletingTransaction?.ReferenceNumber</strong>؟</p>
                <p class="delete-subject">@_deletingTransaction?.Subject</p>
                <p class="delete-warning"><i class="bi bi-info-circle"></i> سيتم حذف جميع المرفقات والملاحظات المرتبطة بها.</p>
            </div>
            <div class="modal-footer">
                <button class="btn-hb-danger" @onclick="HandleDelete" disabled="@_deleting">
                    @if (_deleting)
                    {
                        <span class="hb-spinner" style="width:18px;height:18px;border-width:2px;"></span>
                    }
                    <i class="bi bi-trash3"></i> حذف
                </button>
                <button class="btn-hb-outline" @onclick="CloseDeleteModal">إلغاء</button>
            </div>
        </div>
    </div>
}

@* ===== Reject Confirmation Modal ===== *@
@if (_showRejectModal)
{
    <div class="modal-overlay" @onclick="CloseRejectModal">
        <div class="modal-content modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header modal-header-danger">
                <h3><i class="bi bi-x-octagon"></i> رفض البريد</h3>
                <button class="modal-close" @onclick="CloseRejectModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_rejectError))
                {
                    <div class="hb-alert hb-alert-danger" style="margin-bottom:1rem;">
                        <i class="bi bi-exclamation-triangle-fill"></i> @_rejectError
                    </div>
                }
                <p class="delete-message">رفض البريد <strong>@_rejectingTransaction?.ReferenceNumber</strong></p>
                <p class="delete-subject">@_rejectingTransaction?.Subject</p>
                <div class="hb-form-group" style="margin-top:1rem;">
                    <label class="hb-form-label">سبب الرفض <span class="required-star">*</span></label>
                    <textarea class="hb-form-control note-textarea" rows="6" maxlength="1000"
                              placeholder="اكتب سبب رفض البريد بشكل واضح..."
                              @bind="_rejectionNote" @bind:event="oninput"></textarea>
                    <small class="hb-form-help">سيتم إشعار المرسل بسبب الرفض.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-hb-danger" @onclick="ConfirmReject"
                        disabled="@(_rejecting || string.IsNullOrWhiteSpace(_rejectionNote))">
                    @if (_rejecting)
                    {
                        <span class="hb-spinner" style="width:18px;height:18px;border-width:2px;"></span>
                    }
                    <i class="bi bi-x-octagon"></i> تأكيد الرفض
                </button>
                <button class="btn-hb-outline" @onclick="CloseRejectModal">تراجع</button>
            </div>
        </div>
    </div>
}

@code {
    private List<HBMail.Domain.Entities.Mail> _Mails = [];
    private HashSet<Guid> _ccMailIds = [];
    private bool _loading = true;
    private bool _canCompose;
    private string _searchTerm = "";
    private string _statusFilter = "";
    private string _typeFilter = "";
    private string _priorityFilter = "";
    private int _totalCount, _pendingCount, _inTransitCount, _completedCount;
    private int _currentPage = 1;
    private int _pageSize = 15;
    private int _filteredCount;
    private int _totalPages;

    // Delete modal state
    private bool _showDeleteModal, _deleting;
    private string? _deleteError, _successMessage;
    private HBMail.Domain.Entities.Mail? _deletingTransaction;

    // Reject modal state
    private bool _showRejectModal, _rejecting;
    private string? _rejectError;
    private string? _rejectionNote;
    private HBMail.Domain.Entities.Mail? _rejectingTransaction;

    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessFromQuery { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(SuccessFromQuery))
            _successMessage = SuccessFromQuery;

        // Only admin affairs (DEP-ADM) or SuperAdmin/ITAdmin can compose
        var composeRoles = new[] { "SuperAdmin", "ITAdmin" };
        _canCompose = composeRoles.Any(r => CurrentUser.IsInRole(r));
        if (!_canCompose && CurrentUser.DepartmentId.HasValue)
        {
            _canCompose = await DbContext.Departments.AsNoTracking()
                .AnyAsync(d => d.Id == CurrentUser.DepartmentId.Value && d.Code == "DEP-ADM");
        }

        await LoadMails();
    }

    private async Task LoadMails()
    {
        // Only SuperAdmin/CEO/ITAdmin see all; everyone else sees only their personal Mails
        var globalRoles = new[] { "SuperAdmin", "CEO", "ITAdmin" };
        var hasGlobalAccess = globalRoles.Any(r => CurrentUser.IsInRole(r));

        IQueryable<HBMail.Domain.Entities.Mail> query = DbContext.Mails
            .Include(t => t.SenderBranch)
            .Include(t => t.ReceiverBranch);

        // تحميل معرّفات البريد المنسوخ إليه (CC)
        var userId = CurrentUser.UserId;
        _ccMailIds = (await DbContext.MailCCs.AsNoTracking()
            .Where(cc => cc.UserId == userId)
            .Select(cc => cc.MailId)
            .ToListAsync()).ToHashSet();

        if (!hasGlobalAccess)
        {
            var branchId = CurrentUser.BranchId;
            var deptId = CurrentUser.DepartmentId;
            var isDeptManager = CurrentUser.IsInRole("DepartmentManager") || CurrentUser.IsInRole("DepartmentStaff");

            // الشؤون الإدارية ترى كل البريد (Sent و AssignedToStaff) + بريدها
            var adminDept = await DbContext.Departments.AsNoTracking()
                .FirstOrDefaultAsync(d => d.Code == MailStateMachine.AdminAffairsDeptCode);
            var isAdminAffairs = adminDept != null && deptId == adminDept.Id;

            if (isAdminAffairs)
            {
                // الشؤون ترى: كل Sent/AssignedToStaff + البريد التي شاركت فيها
                query = query.Where(t =>
                    t.Status == MailStatus.Sent ||
                    t.Status == MailStatus.AssignedToStaff ||
                    t.CreatedByUserId == userId ||
                    t.SenderUserId == userId ||
                    t.ReceiverUserId == userId ||
                    _ccMailIds.Contains(t.Id));
            }
            else if (isDeptManager && deptId.HasValue)
            {
                query = query.Where(t =>
                    t.CreatedByUserId == userId ||
                    t.SenderUserId == userId ||
                    t.ReceiverUserId == userId ||
                    t.ManagerNotifiedUserId == userId ||
                    t.SenderDepartmentId == deptId ||
                    t.ReceiverDepartmentId == deptId ||
                    _ccMailIds.Contains(t.Id));
            }
            else
            {
                query = query.Where(t =>
                    t.CreatedByUserId == userId ||
                    t.SenderUserId == userId ||
                    (branchId.HasValue && (t.SenderBranchId == branchId || t.ReceiverBranchId == branchId)) ||
                    t.ReceiverUserId == userId ||
                    t.ManagerNotifiedUserId == userId ||
                    _ccMailIds.Contains(t.Id));
            }
        }

        _Mails = await query
            .OrderByDescending(t => t.CreatedAt)
            .ToListAsync();

        _totalCount = _Mails.Count;
        _pendingCount = _Mails.Count(t => t.Status == MailStatus.Sent);
        _inTransitCount = _Mails.Count(t => t.Status == MailStatus.AssignedToStaff);
        _completedCount = _Mails.Count(t => t.Status is MailStatus.Received or MailStatus.Archived);
        _loading = false;
    }

    private void OpenDeleteModal(HBMail.Domain.Entities.Mail mail)
    {
        _deletingTransaction = mail;
        _deleteError = null;
        _showDeleteModal = true;
    }

    private async Task HandleDelete()
    {
        _deleting = true;
        _deleteError = null;
        try
        {
            DbContext.Mails.Remove(_deletingTransaction!);
            await DbContext.SaveChangesAsync();
            _successMessage = $"تم حذف البريد «{_deletingTransaction!.ReferenceNumber}» بنجاح";
            _showDeleteModal = false;
            await LoadMails();
        }
        catch (Exception ex)
        {
            _deleteError = $"حدث خطأ: {ex.Message}";
        }
        finally { _deleting = false; }
    }

    private void CloseDeleteModal() { _showDeleteModal = false; _deleteError = null; }

    // ===== Receiver / Sender helpers =====
    private bool IsSenderFor(HBMail.Domain.Entities.Mail t)
        => t.SenderUserId == CurrentUser.UserId || t.CreatedByUserId == CurrentUser.UserId;

    private bool IsReceiverOnly(HBMail.Domain.Entities.Mail t)
    {
        if (IsSenderFor(t)) return false;
        return MailStateMachine.IsAuthorizedReceiver(t, CurrentUser.UserId, CurrentUser.BranchId, CurrentUser.DepartmentId);
    }

    // ===== Reject flow =====
    private void OpenRejectModal(HBMail.Domain.Entities.Mail mail)
    {
        _rejectingTransaction = mail;
        _rejectError = null;
        _rejectionNote = null;
        _showRejectModal = true;
    }

    private void CloseRejectModal()
    {
        if (_rejecting) return;
        _showRejectModal = false;
        _rejectError = null;
        _rejectionNote = null;
    }

    private async Task ConfirmReject()
    {
        if (_rejectingTransaction is null || string.IsNullOrWhiteSpace(_rejectionNote)) return;
        _rejecting = true; _rejectError = null;
        try
        {
            var tracked = await DbContext.Mails
                .Include(t => t.History)
                .FirstOrDefaultAsync(t => t.Id == _rejectingTransaction.Id);
            if (tracked is null) { _rejectError = "البريد غير موجودة"; return; }

            var adminDept = await DbContext.Departments.AsNoTracking()
                .FirstOrDefaultAsync(d => d.Code == MailStateMachine.AdminAffairsDeptCode);
            var adminDeptId = adminDept?.Id ?? Guid.Empty;
            var result = StateMachine.Reject(
                tracked, CurrentUser.UserId, CurrentUser.BranchId, CurrentUser.DepartmentId,
                _rejectionNote.Trim());
            if (!result.IsSuccess) { _rejectError = result.Error; return; }

            await DbContext.SaveChangesAsync();

            try
            {
                if (tracked.SenderUserId != CurrentUser.UserId)
                {
                    await NotificationService.NotifyUserAsync(
                        tracked.SenderUserId,
                        $"رفض البريد {tracked.ReferenceNumber}",
                        $"رفض المستلم البريد. السبب: {_rejectionNote!.Trim()}",
                        tracked.Id,
                        NotificationType.MailStatusChanged);
                }
            }
            catch { /* notification failure must not block */ }

            _successMessage = $"تم رفض البريد «{tracked.ReferenceNumber}» وإشعار المرسل";
            _showRejectModal = false;
            _rejectionNote = null;
            await LoadMails();
        }
        catch (Exception ex) { _rejectError = $"حدث خطأ: {ex.Message}"; }
        finally { _rejecting = false; }
    }

    private IEnumerable<HBMail.Domain.Entities.Mail> GetFilteredMails()
    {
        var query = _Mails.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchTerm))
            query = query.Where(t => t.ReferenceNumber.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
                || t.Subject.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));

        if (Enum.TryParse<MailStatus>(_statusFilter, out var status))
            query = query.Where(t => t.Status == status);

        if (Enum.TryParse<MailType>(_typeFilter, out var type))
            query = query.Where(t => t.Type == type);

        if (Enum.TryParse<MailPriority>(_priorityFilter, out var priority))
            query = query.Where(t => t.Priority == priority);

        var filtered = query.ToList();
        _filteredCount = filtered.Count;
        _totalPages = (int)Math.Ceiling((double)_filteredCount / _pageSize);
        if (_currentPage > _totalPages && _totalPages > 0) _currentPage = _totalPages;

        return filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    }

    private void GoToPage(int page)
    {
        _currentPage = Math.Max(1, Math.Min(page, _totalPages));
    }

    private IEnumerable<int> GetPageNumbers()
    {
        var start = Math.Max(1, _currentPage - 2);
        var end = Math.Min(_totalPages, start + 4);
        start = Math.Max(1, end - 4);
        return Enumerable.Range(start, end - start + 1);
    }

    private static string GetStatusLabel(MailStatus s) => s switch
    {
        MailStatus.Sent => "بانتظار الاستلام",
        MailStatus.AssignedToStaff => "موجه لموظف",
        MailStatus.Received => "تم الاستلام",
        MailStatus.Rejected => "مرفوضة",
        MailStatus.Archived => "مؤرشفة",
        _ => s.ToString()
    };

    private static string GetTypeLabel(MailType t) => t switch
    {
        MailType.DocumentDelivery => "تسليم مرفقات",
        MailType.CashTransfer => "تحويل نقدي",
        MailType.InternalDepartment => "داخلي بين الإدارات",
        MailType.BranchToBranch => "بين الفروع",
        MailType.Other => "أخرى",
        _ => t.ToString()
    };

    private static string GetPriorityLabel(MailPriority p) => p switch
    {
        MailPriority.Normal => "عادية",
        MailPriority.Important => "مهمة",
        MailPriority.Urgent => "عاجلة",
        _ => p.ToString()
    };

    private static string GetStatusClass(MailStatus s) => s switch
    {
        MailStatus.Sent => "status-pending",
        MailStatus.AssignedToStaff => "status-in-transit",
        MailStatus.Received => "status-confirmed",
        MailStatus.Rejected => "status-returned",
        MailStatus.Archived => "status-archived",
        _ => ""
    };

    private static string GetStatusIcon(MailStatus s) => s switch
    {
        MailStatus.Sent => "bi bi-send",
        MailStatus.AssignedToStaff => "bi bi-truck",
        MailStatus.Received => "bi bi-check-circle-fill",
        MailStatus.Rejected => "bi bi-x-octagon",
        MailStatus.Archived => "bi bi-archive",
        _ => "bi bi-circle"
    };

    private static string GetPriorityBadgeClass(MailPriority p) => p switch
    {
        MailPriority.Normal => "hb-badge-success",
        MailPriority.Important => "hb-badge-info",
        MailPriority.Urgent => "hb-badge-danger",
        _ => "hb-badge-secondary"
    };

    private static string GetPriorityIcon(MailPriority p) => p switch
    {
        MailPriority.Normal => "bi bi-flag-fill",
        MailPriority.Important => "bi bi-exclamation-circle-fill",
        MailPriority.Urgent => "bi bi-lightning-fill",
        _ => "bi bi-flag"
    };
}
