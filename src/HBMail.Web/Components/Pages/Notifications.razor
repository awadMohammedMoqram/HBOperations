@page "/notifications"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using HBMail.Application.Common.Interfaces
@using HBMail.Domain.Enums
@using Microsoft.EntityFrameworkCore
@inject IAppDbContext DbContext
@inject ICurrentUserService CurrentUser
@inject NavigationManager Navigation

<PageTitle>الإشعارات - بنك حضرموت</PageTitle>

<div class="page-container hb-fade-in">
    <div class="page-title-section">
        <div class="title-with-action">
            <div>
                <h1 class="section-title"><i class="bi bi-bell-fill"></i> الإشعارات</h1>
                <p class="section-subtitle">جميع الإشعارات والتنبيهات الخاصة بك</p>
            </div>
            @if (_notifications.Any(n => !n.IsRead))
            {
                <button class="btn btn-outline" @onclick="MarkAllAsRead">
                    <i class="bi bi-check2-all"></i> تعيين الكل كمقروء
                </button>
            }
        </div>
    </div>

    <!-- Stats -->
    <div class="notif-stats">
        <div class="stat-item">
            <i class="bi bi-bell-fill"></i>
            <span class="stat-number">@_notifications.Count</span>
            <span class="stat-label">إجمالي الإشعارات</span>
        </div>
        <div class="stat-item stat-unread">
            <i class="bi bi-envelope-fill"></i>
            <span class="stat-number">@_notifications.Count(n => !n.IsRead)</span>
            <span class="stat-label">غير مقروءة</span>
        </div>
        <div class="stat-item stat-read">
            <i class="bi bi-envelope-open"></i>
            <span class="stat-number">@_notifications.Count(n => n.IsRead)</span>
            <span class="stat-label">مقروءة</span>
        </div>
    </div>

    @if (_loading)
    {
        <div class="hb-loading"><div class="hb-spinner"></div><span>جاري تحميل الإشعارات...</span></div>
    }
    else if (!_notifications.Any())
    {
        <div class="empty-state">
            <i class="bi bi-bell-slash"></i>
            <h3>لا توجد إشعارات</h3>
            <p>ستظهر الإشعارات هنا عندما يكون هناك تحديثات</p>
        </div>
    }
    else
    {
        <div class="notifications-list">
            @foreach (var notif in _notifications)
            {
                <div class="notif-item @(notif.IsRead ? "" : "unread") @(notif.MailId.HasValue ? "clickable" : "")" @onclick="() => HandleNotifClick(notif)">
                    <div class="notif-icon @GetNotifIconClass(notif.Type)">
                        <i class="bi @GetNotifIcon(notif.Type)"></i>
                    </div>
                    <div class="notif-content">
                        <h4 class="notif-title">@notif.TitleAr</h4>
                        <p class="notif-message">@notif.MessageAr</p>
                        <span class="notif-date">
                            <i class="bi bi-clock"></i> @GetTimeAgo(notif.CreatedAt)
                        </span>
                    </div>
                    @if (!notif.IsRead)
                    {
                        <span class="unread-dot"></span>
                    }
                    @if (notif.MailId.HasValue)
                    {
                        <span class="notif-link-icon"><i class="bi bi-chevron-left"></i></span>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<HBMail.Domain.Entities.Notification> _notifications = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _notifications = await DbContext.Notifications
            .Where(n => n.UserId == CurrentUser.UserId)
            .OrderByDescending(n => n.CreatedAt)
            .Take(100)
            .AsNoTracking()
            .ToListAsync();

        _loading = false;
    }

    private async Task HandleNotifClick(HBMail.Domain.Entities.Notification notif)
    {
        // Mark as read
        if (!notif.IsRead)
        {
            var entity = await DbContext.Notifications.FindAsync(notif.Id);
            if (entity is not null)
            {
                entity.IsRead = true;
                entity.ReadAt = DateTime.UtcNow;
                await DbContext.SaveChangesAsync();
                notif.IsRead = true;
            }
        }

        // Navigate to Mail detail if linked
        if (notif.MailId.HasValue)
        {
            Navigation.NavigateTo($"/mail/{notif.MailId}");
        }
    }

    private async Task MarkAsRead(HBMail.Domain.Entities.Notification notif)
    {
        if (notif.IsRead) return;
        var entity = await DbContext.Notifications.FindAsync(notif.Id);
        if (entity is not null)
        {
            entity.IsRead = true;
            entity.ReadAt = DateTime.UtcNow;
            await DbContext.SaveChangesAsync();
            notif.IsRead = true;
        }
    }

    private async Task MarkAllAsRead()
    {
        var unread = await DbContext.Notifications
            .Where(n => n.UserId == CurrentUser.UserId && !n.IsRead)
            .ToListAsync();

        foreach (var n in unread)
        {
            n.IsRead = true;
            n.ReadAt = DateTime.UtcNow;
        }

        await DbContext.SaveChangesAsync();

        foreach (var n in _notifications.Where(n => !n.IsRead))
            n.IsRead = true;
    }

    private static string GetNotifIcon(NotificationType t) => t switch
    {
        NotificationType.MailCreated => "bi-plus-circle",
        NotificationType.MailStatusChanged => "bi-arrow-repeat",
        NotificationType.MailAssigned => "bi-person-check",
        NotificationType.DocumentUploaded => "bi-cloud-upload",
        NotificationType.MailOverdue => "bi-alarm",
        NotificationType.SystemAlert => "bi-shield-exclamation",
        _ => "bi-bell"
    };

    private static string GetNotifIconClass(NotificationType t) => t switch
    {
        NotificationType.MailCreated => "icon-success",
        NotificationType.MailStatusChanged => "icon-info",
        NotificationType.MailAssigned => "icon-primary",
        NotificationType.DocumentUploaded => "icon-gold",
        NotificationType.MailOverdue => "icon-danger",
        NotificationType.SystemAlert => "icon-warning",
        _ => "icon-primary"
    };

    private static string GetTimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "الآن";
        if (diff.TotalMinutes < 60) return $"منذ {(int)diff.TotalMinutes} دقيقة";
        if (diff.TotalHours < 24) return $"منذ {(int)diff.TotalHours} ساعة";
        if (diff.TotalDays < 7) return $"منذ {(int)diff.TotalDays} يوم";
        return AppTime.FormatYemen(dt, "yyyy/MM/dd");
    }
}
